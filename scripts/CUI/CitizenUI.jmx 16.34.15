            <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor" enabled="true">
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="script">import java.util.Base64;

String encodedPwd = props.get(&quot;password&quot;);

log.info(&quot;Encoded Password: &quot; + encodedPwd);

String decodedPwd = new String(
    Base64.getDecoder().decode(encodedPwd),
    &quot;UTF-8&quot;
);

vars.put(&quot;password&quot;, decodedPwd);

log.info(&quot;Decoded Password: &quot; + decodedPwd);</stringProp>

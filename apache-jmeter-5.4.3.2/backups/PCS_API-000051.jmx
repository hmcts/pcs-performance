        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Decoder" enabled="false">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import java.util.Base64

// Create a decoder instance
def decoder = Base64.getDecoder()

// --- Process Parameter 1 (Password) ---
String encodedPass = vars.get(&quot;password&quot;)
if (encodedPass) {
    byte[] decodedBytes = decoder.decode(encodedPass)
    vars.put(&quot;clear_pass&quot;, new String(decodedBytes))
}

// --- Process Parameter 2 (Token) ---
String encodedToken = vars.get(&quot;clientsecret&quot;)
if (encodedToken) {
    byte[] decodedBytes = decoder.decode(encodedToken)
    vars.put(&quot;clear_secret&quot;, new String(decodedBytes))
}</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>

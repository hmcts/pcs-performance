              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="script">import org.apache.commons.codec.binary.Base64;

// 1. Get the encoded values from your CSV columns
String encPass = vars.get(&quot;password&quot;);
String encToken = vars.get(&quot;clientsecret&quot;);

try {
    // 2. Decode Password
    if (encPass != null &amp;&amp; !encPass.isEmpty()) {
        byte[] decodedPass = Base64.decodeBase64(encPass.getBytes());
        vars.put(&quot;clear_pass&quot;, new String(decodedPass));
    }

    // 3. Decode Token
    if (encToken != null &amp;&amp; !encToken.isEmpty()) {
        byte[] decodedToken = Base64.decodeBase64(encToken.getBytes());
        vars.put(&quot;clear_secret&quot;, new String(decodedToken));
    }
} catch (Exception e) {
    log.error(&quot;BeanShell Decoding Error: &quot; + e.getMessage());
}</stringProp>
            </BeanShellPreProcessor>
            <hashTree/>
          </hashTree>
        </hashTree>

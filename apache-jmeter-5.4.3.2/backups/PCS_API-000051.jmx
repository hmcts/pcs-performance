      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="setFilePaths" enabled="false">
        <stringProp name="TestPlan.comments">this sets dynamically csv path based on no of slaves</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import org.apache.jmeter.services.FileServer

def basePath  = FileServer.getFileServer().getBaseDir();
log.info(&quot;JMeter base dir: &quot; + basePath)
def csvPath = basePath + &quot;/GET-Courts/Perf-Postcodes.csv&quot;;
def csvPath2 = basePath + &quot;/GET-Courts/userdetails.csv&quot;;

props.put(&quot;postcodeCsvDatapath&quot;, csvPath);
props.put(&quot;userdetailsCsvDatapath&quot;, csvPath2);
log.info(&quot;postcode csv path: &quot; + props.get(&quot;postcodeCsvDatapath&quot;))
log.info(&quot;userdetails csv path: &quot; + props.get(&quot;userdetailsCsvDatapath&quot;))</stringProp>
      </JSR223PostProcessor>

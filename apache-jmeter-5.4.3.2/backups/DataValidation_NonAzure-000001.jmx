//def lines = csvfile.readLines();

//lines.each {line -&gt;
//	log.info(&quot;line: &quot; + line);

	String line = vars.get(&quot;line&quot;);

	def courtLines = line.split(&quot;,&quot;);
//	log.info(&quot;CaseURN: &quot; + courtLines[0]);
	vars.put(&quot;NEW_URN&quot;, courtLines[0]);
//	vars.putObject(&quot;URN_DATA&quot;, courtLines[0]);


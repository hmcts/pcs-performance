            <stringProp name="script">vars.put(&quot;SCENARIO_NAME&quot;, ctx.getThreadGroup().getName().toString());
vars.put(&quot;USER&quot;, &quot;OTHER&quot;);

//import java.util.List;
//import java.util.ArrayList;

          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="MANUALLY Confirm Column for Case_URN " enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;SCENARIO_NAME&quot;, ctx.getThreadGroup().getName().toString());
vars.put(&quot;USER&quot;, &quot;OTHER&quot;);

//import java.util.List;

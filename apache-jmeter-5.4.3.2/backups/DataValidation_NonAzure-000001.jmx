// 		courtroom: found

vars.put(&quot;invalidFlag&quot;, &quot;False&quot;);
log.info(&quot;resultingApplicationsCounter: &quot; + vars.get(&quot;resultingApplicationsCounter&quot;));

log.info(&quot;caseId: &quot; + vars.get(&quot;caseId&quot;));

            </HTTPSamplerProxy>
            <hashTree>
              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="addDynatraceHeader" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import org.apache.jmeter.protocol.http.control.Header;
 
def headerValue = new StringBuilder();
def trid = org.apache.jmeter.util.JMeterUtils.getProperty(&quot;testrunId&quot;);
def groupName = ctx.getThreadGroup().getName();
def samplerName = sampler.getName();
int threadNum = ctx.getThreadGroup().getNumThreads();


try {
//DATE_ID is just a TimeStamp (defined in the Test Plan)
def DATEID = vars.get(&quot;DATE_ID&quot;);
 
// LoopCount the amount of loops
def LoopCount = vars.get(&quot;LoopCount&quot;);
 
// VU Count (VirtualUser Count) same as Num of Threads
 def VUCount = vars.get(&quot;VUCount&quot;);

 def caseUrn = vars.get(&quot;NEW_URN&quot;);

 
//LSN Load Script Name - name of the load testing script. This groups a set of test steps that make up a multi-step transaction (for example, an online purchase).
headerValue.append(&quot;LSN=&quot;+groupName+&quot;;&quot;);
 
// LTN The Load Test Name uniquely identifies a test execution (for example, 6h Load Test – June 25)
//headerValue.append(&quot;LTN=LoadTest via Radu&apos;s JMeter - &quot; +groupName+&quot; - VU(&quot; + threadNum +&quot;) Loops(&quot;+LoopCount+&quot;) - &quot;+ DATEID+&quot;;&quot;);
 
// Test Step Name is a logical test step within your load testing script (for example, Login or Add to cart.
headerValue.append(&quot;TSN=&quot;+samplerName+&quot;;&quot;);
headerValue.append(&quot;caseType=&quot;+vars.get(&quot;caseType&quot;)+&quot;;&quot;);
headerValue.append(&quot;caseUrn=&quot;+vars.get(&quot;caseUrn&quot;)+&quot;;&quot;);

//headerValue.append(&quot;AN= &quot; + props.getProperty(&quot;NEW_URN&quot;) +&quot;;&quot;);
 

headerValue.append(&quot;VU=&quot;+ctx.getThreadNum()+&quot;;&quot;);

headerValue.append(&quot;SI=JMeter on Load test for CP -SPI Complex;&quot;);

if(sampler.getClass().getSuperclass().getName().toString().contains(&quot;HTTPSamplerBase&quot;)) {
   sampler.headerManager.removeHeaderNamed(&apos;X-Dynatrace-Test&apos;);
   sampler.headerManager.add(new Header(&apos;X-Dynatrace-Test&apos;,  headerValue.toString()));
    }
} catch(Exception e) {
log.info(&quot;Error in adding Dynatrace Header&quot; + e);	
}
</stringProp>

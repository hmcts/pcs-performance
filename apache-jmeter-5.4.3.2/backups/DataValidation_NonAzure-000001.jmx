          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Evaluate Validity Allocated With" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">//	For Allocated Without We expect
//		caseID exists in both USQ and Progression
//		caseMaterial is not found
//		SJP is false
//		Hearing Id exists
// 		courtroom: found

vars.put(&quot;invalidFlag&quot;, &quot;False&quot;);

log.info(&quot;caseId: &quot; + vars.get(&quot;caseId&quot;));
if (vars.get(&quot;caseId&quot;) == &quot;notFound&quot;)
{
	vars.put(&quot;invalidFlag&quot;, &quot;True&quot;);
	log.info(&quot;invalidFlag&quot; + vars.get(&quot;invalidFlag&quot;));
}

log.info(&quot;caseStatus: &quot; + vars.get(&quot;caseStatus&quot;));
if (vars.get(&quot;caseStatus&quot;) == &quot;notFound&quot; || vars.get(&quot;caseStatus&quot;) == &quot;INACTIVE&quot;)
{
	vars.put(&quot;invalidFlag&quot;, &quot;True&quot;);
	log.info(&quot;invalidFlag&quot; + vars.get(&quot;invalidFlag&quot;));
}


log.info(&quot;caseIdProgression: &quot; + vars.get(&quot;caseIdProgression&quot;));
if (vars.get(&quot;caseIdProgression&quot;) == &quot;notFound&quot;)
{
	vars.put(&quot;invalidFlag&quot;, &quot;True&quot;);
	log.info(&quot;invalidFlag: &quot; + vars.get(&quot;invalidFlag&quot;));
}

log.info(&quot;documentName: &quot; + vars.get(&quot;documentName&quot;));
if (vars.get(&quot;documentName&quot;) == &quot;notFound&quot;)
{
	vars.put(&quot;invalidFlag&quot;, &quot;True&quot;);
	log.info(&quot;invalidFlag: &quot; + vars.get(&quot;invalidFlag&quot;));
}

log.info(&quot;courtRoom: &quot; + vars.get(&quot;courtRoom&quot;));
if (vars.get(&quot;courtRoom&quot;) == &quot;notFound&quot;)
{
	vars.put(&quot;invalidFlag&quot;, &quot;True&quot;);
	log.info(&quot;invalidFlag: &quot; + vars.get(&quot;invalidFlag&quot;));
}

log.info(&quot;hearingsHearingId: &quot; + vars.get(&quot;hearingsHearingId&quot;));
if (vars.get(&quot;hearingsHearingId&quot;) == &quot;notFound&quot;)
{
	vars.put(&quot;invalidFlag&quot;, &quot;True&quot;);
	log.info(&quot;invalidFlag: &quot; + vars.get(&quot;invalidFlag&quot;));
}

log.info(&quot;sjpFlag&quot; + vars.get(&quot;sjpFlag&quot;));
if (vars.get(&quot;sjpFlag&quot;) != &quot;false&quot;)
{
	vars.put(&quot;invalidFlag&quot;, &quot;True&quot;);
	log.info(&quot;invalidFlag: &quot; + vars.get(&quot;invalidFlag&quot;));
}
</stringProp>
          </JSR223Sampler>

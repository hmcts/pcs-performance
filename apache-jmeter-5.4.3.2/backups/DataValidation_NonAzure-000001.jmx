              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Write to File" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">
path  = vars.get(&quot;VALID_FILENAME_OUT&quot;);

FileWriter fWriter = new FileWriter(path, true);
BufferedWriter buff = new BufferedWriter(fWriter);

buff.write(vars.get(&quot;line&quot;) + &quot;\r\n&quot;);

buff.close();
fWriter.close();


//log.info(&quot;LINE: &quot; + vars.get(&quot;line&quot;));

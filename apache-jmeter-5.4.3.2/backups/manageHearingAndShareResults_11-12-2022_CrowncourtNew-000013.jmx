                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">true</stringProp>
                            <stringProp name="script">if (vars.get(&quot;hearingSharedStatus&quot;) != &quot;NO_HEARING_STATUS&quot;) {
	vars.put(&quot;HearingStatusNotificationPollingEnded&quot;, &quot;true&quot;);
     prev.setSuccessful(true);
     vars.put(&quot;resultshared&quot;,&quot;true&quot;);
}
else
{
	current_iteration = vars.get(&quot;pollingIterationCounter&quot;);
	new_iteration_value = Integer.parseInt(current_iteration) + 1 ;
	vars.put(&quot;pollingIterationCounter&quot;, String.valueOf(new_iteration_value));
}
</stringProp>
                          </JSR223PostProcessor>

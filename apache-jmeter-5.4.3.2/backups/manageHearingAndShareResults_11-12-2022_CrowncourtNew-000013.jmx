                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="computePayloadForAddAttendees" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import groovy.json.*
def faker = new com.github.javafaker.Faker();
def payloadBuilder = new JsonBuilder()

payloadBuilder  {
  prosecutionCounsel {
    id UUID.randomUUID().toString()
    title faker.name().title()
    firstName faker.name().firstName()
    middleName &quot;&quot;
    lastName faker.name().lastName()
    status &quot;Google&quot;
    prosecutionCases([vars.get(&quot;CASE_ID&quot;)])
    attendanceDays([vars.get(&quot;HEARING_DATE&quot;)])
  }
}
def addAttendeesPayload = payloadBuilder.toPrettyString()
vars.put(&quot;addAttendeesPayload&quot;,addAttendeesPayload);


log.info(&quot;HEARING ID: &quot; + vars.get(&quot;HEARING_ID&quot;));
</stringProp>
                </JSR223Sampler>

                      <hashTree>
                        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="reconstructAmendDraftResults" enabled="true">
                          <stringProp name="scriptLanguage">groovy</stringProp>
                          <stringProp name="parameters"></stringProp>
                          <stringProp name="filename"></stringProp>
                          <stringProp name="cacheKey">true</stringProp>
                          <stringProp name="script">import groovy.json.*
import org.apache.jmeter.services.FileServer

def resLinesMap = [:];

//def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
def weekDate = java.time.LocalDate.parse(vars.get(&quot;HEARING_DATE&quot;));
def fixedDate = weekDate.plusDays(10).toString();

//log.info(&quot;fixedDate &quot; + fixedDate);
vars.put(&quot;fixedDate&quot;, fixedDate)
vars.put(&quot;newFixedDate&quot;, fixedDate);

log.info(&quot;first&quot; + String.valueOf(vars.getObject(&quot;firstSaveDraftResult&quot;)));
log.info(&quot;last&quot; + String.valueOf(vars.getObject(&quot;lastSaveDraftResult&quot;)));

def saveDraftResultsPayload = (vars.getObject(&quot;lastSaveDraftResult&quot;).empty) ? 
                             vars.getObject(&quot;firstSaveDraftResult&quot;) : vars.getObject(&quot;lastSaveDraftResult&quot;)  
def finalResultLines = [:];
def parsed = new JsonSlurper().parseText(saveDraftResultsPayload)
def amendmentReason = [:]
def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ISO_INSTANT;

if (vars.get(&quot;resultCode&quot;).equals(&apos;A&apos;)) {
    resultLines = parsed.resultLines
    for (rel in resultLines) {
        def modifiedResultLineMap =[:]
        def isResultLineAmending = false
       
        if (rel.getValue().originalText.toString().equals(&quot;nhccs&quot;)) {
            isResultLineAmending = true
            def resultPrompts = rel.getValue().resultPrompts
            for (prompt in resultPrompts) {
                if (prompt.label.equals(&quot;Date and time to be fixed&quot;)) {
                    fixedDate = java.time.LocalDate.parse(prompt.value.value).plusDays(2).toString()
                    prompt.value.value = fixedDate;
                    vars.put(&quot;newFixedDate&quot;, fixedDate);
                }
            }
            amendmentReason = amendmentReason + [&quot;amendmentReason&quot;:
                                                         [&quot;id&quot;: &quot;a02018a1-915c-3343-95ad-abc5f99b339a&quot;, &quot;seqNo&quot;: 20, &quot;reasonDescription&quot;: &quot;Error or Omission in result announced in court (Amendment under the Slip rule)&quot;]]
            def todayAmendmentDate = java.time.ZonedDateTime.now().format(java.time.format.DateTimeFormatter.ISO_INSTANT).toString();                                             
            amendmentReason = amendmentReason + [&quot;amendmentDate&quot;: todayAmendmentDate]
        }
        modifiedResultLineMap = isResultLineAmending ? rel.getValue() + amendmentReason : rel.getValue()
        finalResultLines = finalResultLines + ([(rel.getKey()): modifiedResultLineMap]);
    }
}
parsed.resultLines = finalResultLines;
newJsonOut = JsonOutput.prettyPrint(JsonOutput.toJson(parsed))
vars.put(&quot;amendDraftResultsPayload&quot;, newJsonOut);

//log.info(&quot;final result Map &quot; + newJsonOut);
log.info(&quot;newFixedDate: &quot; + vars.get(&quot;newFixedDate&quot;));

                             </stringProp>
                        </JSR223Sampler>

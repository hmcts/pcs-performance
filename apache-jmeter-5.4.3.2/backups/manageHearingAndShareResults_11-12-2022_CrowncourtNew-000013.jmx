                            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract hearing shared status " enabled="true">
                              <stringProp name="JSONPostProcessor.referenceNames">hearingSharedStatus</stringProp>
                              <stringProp name="JSONPostProcessor.jsonPathExprs">$.events[?(@._metadata.correlation.client==&apos;${cppClientCorrelationId}&apos; &amp;&amp; @._metadata.name==&apos;public.events.hearing.hearing-resulted-success&apos; &amp;&amp; @._metadata.stream.id==&apos;${HEARING_ID}&apos;)]</stringProp>
                              <stringProp name="JSONPostProcessor.match_numbers">0</stringProp>
                              <stringProp name="JSONPostProcessor.defaultValues">NO_HEARING_STATUS</stringProp>
                              <boolProp name="JSONPostProcessor.compute_concat">true</boolProp>
                              <stringProp name="TestPlan.comments">.hearing.hasSharedResults</stringProp>

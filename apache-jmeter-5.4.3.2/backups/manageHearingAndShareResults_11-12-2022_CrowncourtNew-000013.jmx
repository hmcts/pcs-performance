        for(r in rel){
            val = r.resultLineId
            tempMap=[&quot;resultLineId&quot;:r.resultLineId,&quot;childResultLineIds&quot;:r.childResultLineIds]
            resLines = new JsonSlurper().parseText(tempText).resultLines
            for(resLine in resLines){

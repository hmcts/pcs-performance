                              <stringProp name="HTTPSampler.port"></stringProp>
                              <stringProp name="HTTPSampler.protocol"></stringProp>
                              <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                              <stringProp name="HTTPSampler.path">api/notification-query-api/query/api/rest/notifications/subscriptions/${subscriptionID}/events?clientCorrelationId=${cppClientCorrelationIdForAmendDraftResult}</stringProp>
                              <stringProp name="HTTPSampler.method">GET</stringProp>
                              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                              <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
                              <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                              <boolProp name="HTTPSampler.image_parser">true</boolProp>
                              <boolProp name="HTTPSampler.concurrentDwn">true</boolProp>
                              <stringProp name="HTTPSampler.concurrentPool">2</stringProp>
                              <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                              <stringProp name="HTTPSampler.connect_timeout"></stringProp>
                              <stringProp name="HTTPSampler.response_timeout"></stringProp>
                            </HTTPSamplerProxy>
                            <hashTree>
                              <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header manager" enabled="true">
                                <collectionProp name="HeaderManager.headers">
                                  <elementProp name="Accept" elementType="Header">
                                    <stringProp name="Header.name">Accept</stringProp>
                                    <stringProp name="Header.value">application/vnd.notification.events+json</stringProp>
                                  </elementProp>
                                </collectionProp>
                              </HeaderManager>
                              <hashTree/>
                              <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Ignore errors" enabled="true">
                                <collectionProp name="Asserion.test_strings">
                                  <stringProp name="49586">200</stringProp>
                                  <stringProp name="51511">403</stringProp>
                                  <stringProp name="51512">404</stringProp>
                                </collectionProp>
                                <stringProp name="TestPlan.comments">Ignore 403 status as our new notification subscription might not be ready</stringProp>
                                <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
                                <boolProp name="Assertion.assume_success">true</boolProp>
                                <intProp name="Assertion.test_type">40</intProp>
                                <stringProp name="Assertion.custom_message"></stringProp>
                              </ResponseAssertion>
                              <hashTree/>
                              <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract hearing shared status " enabled="true">
                                <stringProp name="JSONPostProcessor.referenceNames">hearingIdForAmendedEvent</stringProp>
                                <stringProp name="JSONPostProcessor.jsonPathExprs">$.events[?(@._metadata.correlation.client==&apos;${cppClientCorrelationIdForAmendDraftResult}&apos; &amp;&amp; @._metadata.name==&apos;public.hearing.event-amended&apos;)]._metadata.stream.id</stringProp>
                                <stringProp name="JSONPostProcessor.match_numbers">0</stringProp>
                                <stringProp name="JSONPostProcessor.defaultValues">NO_HEARING_STATUS</stringProp>
                                <boolProp name="JSONPostProcessor.compute_concat">true</boolProp>
                              </JSONPostProcessor>
                              <hashTree/>
                              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Evaluate whether the results are shared sucessfully" enabled="true">
                                <stringProp name="scriptLanguage">groovy</stringProp>
                                <stringProp name="parameters"></stringProp>
                                <stringProp name="filename"></stringProp>
                                <stringProp name="cacheKey">true</stringProp>
                                <stringProp name="script">if (vars.get(&quot;hearingIdForAmendedEvent&quot;).equals(vars.get(&quot;HEARING_ID&quot;))) {
	vars.put(&quot;AmendDraftHearingResultsNotificationPollingEnded&quot;, &quot;true&quot;);
//     prev.setResponseMessage(&quot;hearing results are shared sucessfully&quot;);
     prev.setSuccessful(true);
//     prev.setSampleLabel(&quot;Hearing results shared &quot; + vars.get(&quot;caseType&quot;));
} else {
	current_iteration = vars.get(&quot;poolingIterationCounter&quot;);
	new_iteration_value = Integer.parseInt(current_iteration) - 1 ;
	log.info(&quot;new iteration value  &quot; + new_iteration_value);
	//pooling didin&apos;t return case Id - quit pooling 
	if (new_iteration_value == 0){
	 vars.put(&quot;AmendDraftHearingResultsNotificationPollingEnded&quot;, &quot;true&quot;);	
	 log.info(&quot;hearing shared results are not saved for  ===&gt;  &quot; + vars.get(&quot;NEW_URN&quot;) + &quot;,&quot; + vars.get(&quot;HEARING_ID&quot;) +   &quot;subscriptionID &quot;  +  vars.get(&quot;subscriptionID&quot;) + &quot; cppClientCorrelationId &quot; +  vars.get(&quot;cppClientCorrelationId&quot;) );	
	 
//	 vars.put(&quot;publicEventSharedFailToRaise&quot;, &quot;true&quot;);
      prev.setSuccessful(false);
      prev.setResponseCode(&quot;418&quot;);
	}
	vars.put(&quot;poolingIterationCounter&quot;, String.valueOf(new_iteration_value));
}
</stringProp>

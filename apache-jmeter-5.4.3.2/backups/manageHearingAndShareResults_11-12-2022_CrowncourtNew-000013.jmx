                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.node.ObjectNode;
import com.flipkart.zjsonpatch.JsonDiff;
import com.fasterxml.jackson.databind.ObjectMapper;
import java.io.IOException;  
import java.text.ParseException;  
import com.fasterxml.jackson.core.JsonParseException;  
import com.fasterxml.jackson.databind.JsonMappingException;  
import com.fasterxml.jackson.databind.JsonNode;  
import com.fasterxml.jackson.databind.ObjectMapper;  

//import com.github.fge.jsonschema.core.exceptions.ProcessingException;
//import com.github.fge.jsonschema.core.report.ProcessingMessage;
//import com.github.fge.jsonschema.core.report.ProcessingReport;
//import com.github.fge.jsonschema.main.JsonSchema;
//import com.github.fge.jsonschema.main.JsonSchemaFactory;

ObjectMapper mapper = new ObjectMapper();

//vars.put(&quot;firstSaveDraftResult&quot;, &quot;{\&quot;a\&quot;: 0,\&quot;b\&quot;: [1,2]}&quot;);
//vars.put(&quot;finalSaveDraftResult&quot;, &quot;{\&quot;b\&quot;: [1,2,0]}&quot;);

JsonNode json_1_out = mapper.readTree(vars.get(&quot;SaveDraftResult1&quot;));
JsonNode json_2_out = mapper.readTree(vars.get(&quot;SaveDraftResult2&quot;));
JsonNode json_3_out = mapper.readTree(vars.get(&quot;SaveDraftResult3&quot;));
JsonNode json_4_out = mapper.readTree(vars.get(&quot;SaveDraftResult4&quot;));
JsonNode json_5_out = mapper.readTree(vars.get(&quot;SaveDraftResult5&quot;));
JsonNode json_6_out = mapper.readTree(vars.get(&quot;SaveDraftResult6&quot;));

//1-2
JsonNode patch_1 = JsonDiff.asJson(json_1_out, json_2_out);
log.info(patch_1.toString());
//2-3
JsonNode patch_2 = JsonDiff.asJson(json_2_out, json_3_out);
log.info(patch_2.toString());
//3-4
JsonNode patch_3 = JsonDiff.asJson(json_3_out, json_4_out);
log.info(patch_3.toString());
//4-5
JsonNode patch_4 = JsonDiff.asJson(json_4_out, json_5_out);
log.info(patch_4.toString());
//5-6
JsonNode patch_5 = JsonDiff.asJson(json_5_out, json_6_out);
log.info(patch_5.toString());

//def JsonNode = new com.flipkart.zjsonpatch.JsonNode();

//val jsonPatch: JsonPatch = JsonPatch.fromJson(objectMapper.readTree(patch))

vars.put(&quot;CASE_ID&quot;, &quot;notFound&quot;);
log.info(vars.get(&quot;CASE_ID&quot;));


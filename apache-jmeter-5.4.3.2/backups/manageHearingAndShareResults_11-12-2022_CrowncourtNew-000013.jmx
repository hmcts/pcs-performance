                              <stringProp name="JSONPostProcessor.jsonPathExprs">$.events[?(@._metadata.correlation.client==&apos;${cppClientCorrelationId}&apos; &amp;&amp; @._metadata.name==&apos;public.events.hearing.hearing-resulted-success&apos; &amp;&amp; @._metadata.stream.id==&apos;${HEARING_ID}&apos;)]</stringProp>

                                <stringProp name="JSONPostProcessor.jsonPathExprs">$.events[?(@._metadata.correlation.client==&apos;${cppClientCorrelationIdForAmendDraftResult}&apos; &amp;&amp; @._metadata.name==&apos;public.hearing.event-amended&apos;)]._metadata.stream.id</stringProp>

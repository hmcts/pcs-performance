                    <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="computePayloadForSharedResultOriginal" enabled="false">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">import groovy.json.JsonBuilder;
import groovy.json.JsonSlurper;
import groovy.json.*
import org.apache.jmeter.services.FileServer

def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
def weekDate = java.time.LocalDate.parse(vars.get(&quot;HEARING_DATE&quot;));
def fixedDate = weekDate.plusDays(10).toString();

log.info(&quot;Share1.............&quot;)

//log.info(&quot;fixedDate &quot; + fixedDate);
vars.put(&quot;fixedDate&quot;, fixedDate)

def filePath = vars.get(&quot;baseDir&quot;) + &quot;/shared/payloads/shared-results/CCII.json&quot;
//def filePath = vars.get(&quot;baseDir&quot;) + &quot;/shared/payloads/shared-results/&quot; + vars.get(&quot;resultCode&quot;) + &quot;.json&quot;;
def sharedDate = new Date().format(&apos;yyyy-MM-dd&apos;).toString();
vars.put(&quot;SHAREDDATE&quot;, sharedDate);
def orderedDate = vars.get(&quot;HEARING_DATE&quot;);


def fileContent = new File(filePath).getText()
  fileContent = fileContent.replace(&quot;FIXEDDATE&quot;, vars.get(&quot;fixedDate&quot;))
def newJsonParsed =  new JsonSlurper().parseText(fileContent)
resultLinesList = []

log.info(&quot;Share2.............&quot;)

for(lineId in vars.getObject(&quot;resultlineIdsMap&quot;)){
    newJsonParsed =  new JsonSlurper().parseText(fileContent)

        if(lineId.valid){
            for(resultLine in newJsonParsed.resultLines){
                if(resultLine.shortCode.equalsIgnoreCase(lineId.originalText)){               	
                    resultLine[&quot;defendantId&quot;]= lineId.defendantId
                    resultLine[&quot;masterDefendantId&quot;]= lineId.defendantId
                    resultLine[&quot;offenceId&quot;]= lineId.offenceId
                    resultLine[&quot;orderedDate&quot;] = orderedDate
                    resultLine[&quot;caseId&quot;]= lineId.caseId
                    resultLine[&quot;resultLineId&quot;] = lineId.resultLineId
                    resultLine[&quot;childResultLineIds&quot;]= lineId.childResultLineIds
                    resultLine[&quot;sharedDate&quot;] = sharedDate
                    resultLinesList = resultLinesList + resultLine
                }
            }
        }        
}


newJsonParsed.courtClerk.userId = vars.get(&quot;USER_ID&quot;);
newJsonParsed.resultLines = resultLinesList
finalPayload=JsonOutput.prettyPrint(JsonOutput.toJson(newJsonParsed))
vars.put(&quot;sharedResultPayload&quot;, finalPayload);

</stringProp>
                    </JSR223Sampler>
                    <hashTree/>
                    <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="computePayloadForSharedResultTrial" enabled="true">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">import groovy.json.JsonBuilder;
import groovy.json.JsonSlurper;
import groovy.json.JsonOutput;

def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
def weekDate = java.time.LocalDate.parse(vars.get(&quot;HEARING_DATE&quot;));
def fixed_Date = weekDate.plusDays(10).toString();
vars.put(&quot;FIXED_DATE&quot;, fixed_Date)

def filePath = vars.get(&quot;baseDir&quot;) + &quot;/shared/payloads/shared-results/A_Crowncourt.json&quot;
def sharedDate = new Date().format(&apos;yyyy-MM-dd&apos;).toString();
vars.put(&quot;SHAREDDATE&quot;, sharedDate);
def orderedDate = new Date().format(&apos;yyyy-MM-dd&apos;).toString();
def jsonSlurper = new JsonSlurper();
def allDefendants = vars.getObject(&quot;DEFENDANTID_ALL&quot;).split(&apos;,&apos;);

vars.put(&quot;noOfDefendants&quot;, allDefendants.size().toString());
def prosecutionCaseDetails = jsonSlurper.parseText(vars.getObject(&quot;prosecutionCase&quot;));

def fileContent = new File(filePath).getText()
def currentRelList = []
def currentResLinesMap = []
def lastRelList = []
def lastResLinesMap = []
def listOfMaps = []
def json_6 = &quot;&quot;
def resultLinesMapList = []

def parsed = jsonSlurper.parseText(fileContent)
def relations = parsed.relations

// ✅ Null-safe set for IDs
Set ids = []
for (rel in relations) {
    def childIds = rel.childResultLineIds ?: []  // default to empty list
    ids += childIds
    ids.add(rel.resultLineId)
}

allDefendants.eachWithIndex { defendantId, dInd -&gt;

    def matchedDefendant = prosecutionCaseDetails.defendants.findAll { it.id == defendantId }

    // ✅ Defensive check
    if (!matchedDefendant || !matchedDefendant.first()?.offences) {
        log.warn(&quot;No offences found for defendant: $defendantId&quot;)
        return  // or continue if inside a loop
    }

    def allOffences = matchedDefendant.first().offences.collect { it.id }

    allOffences.eachWithIndex { offenceId, oInd -&gt;
        def tempText = fileContent
        def tempMap = [:]

        tempText = tempText.replace(&quot;DEFENDANTID&quot;, defendantId)
                .replace(&quot;OFFENCEID&quot;, offenceId)
                .replace(&quot;HEARINGID&quot;, vars.get(&quot;HEARING_ID&quot;))
                .replace(&quot;HEARINGDAY&quot;, vars.get(&quot;HEARING_DATE&quot;))
                .replace(&quot;CASEID&quot;, vars.get(&quot;CASE_ID&quot;))
                .replace(&quot;ORDEREDDATE&quot;, orderedDate)
                .replace(&quot;FIXED_DATE&quot;, fixed_Date) 
                .replace(&quot;SHAREDDATE&quot;, sharedDate)

        for (id in ids) {
            def newChildUUID = UUID.randomUUID().toString()
            tempText = tempText.replace(id, newChildUUID)
            tempMap.put(id, newChildUUID)
        }

        def relList = new JsonSlurper().parseText(tempText).relations
        for (r in relList) {
            def val = r.resultLineId
            tempMap = [
                &quot;resultLineId&quot;: r.resultLineId,
                &quot;childResultLineIds&quot;: r.childResultLineIds
            ]
            def resLines = new JsonSlurper().parseText(tempText).resultLines
            for (resLine in resLines) {
                def resLineVal = resLine.getValue()
                if (resLineVal.resultLineId.equalsIgnoreCase(val)) {
                    tempMap.put(&quot;valid&quot;, resLineVal.valid)
                    tempMap.put(&quot;defendantId&quot;, defendantId)
                    tempMap.put(&quot;offenceId&quot;, offenceId)
                    tempMap.put(&quot;originalText&quot;, resLineVal.originalText)
                    tempMap.put(&quot;caseId&quot;, resLineVal.caseId)
                }
            }
            resultLinesMapList.add(tempMap)
        }

        if (dInd == 0 &amp;&amp; oInd == 0) {
            json_6 = tempText
            vars.putObject(&quot;sharedResultPayload&quot;, json_6);
            def parsedJson = new JsonSlurper().parseText(tempText)
            lastRelList = parsedJson.relations
            lastResLinesMap = parsedJson.resultLines
        } else {
            def tempParsed = new JsonSlurper().parseText(tempText)
            currentRelList += tempParsed.relations
            currentResLinesMap += tempParsed.resultLines
        }
    }
}

// ✅ Log values to verify before final merge
log.info(&quot;lastRelList: ${lastRelList?.size()}&quot;)
log.info(&quot;currentRelList: ${currentRelList?.size()}&quot;)
log.info(&quot;lastResLinesMap: ${lastResLinesMap?.size()}&quot;)
log.info(&quot;currentResLinesMap: ${currentResLinesMap?.size()}&quot;)

// ✅ Null-safe additions
parsed.hearingId = vars.get(&quot;HEARING_ID&quot;)
parsed.hearingDay = vars.get(&quot;HEARING_DATE&quot;)
parsed.relations = (lastRelList ?: []) + (currentRelList ?: [])
parsed.resultLines = (lastResLinesMap ?: []) + (currentResLinesMap ?: [])
</stringProp>
                    </JSR223Sampler>
                    <hashTree/>
                    <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="computePayloadForSharedResultTrial for CC" enabled="false">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">import groovy.json.JsonBuilder
import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.time.LocalDate
import java.time.format.DateTimeFormatter

def DATETIME_FORMAT = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)
def weekDate = LocalDate.parse(vars.get(&quot;HEARING_DATE&quot;))
def fixedDate = weekDate.plusDays(20).toString()
vars.put(&quot;FIXEDDATE&quot;, fixedDate)

def filePath = vars.get(&quot;baseDir&quot;) + &quot;/shared/payloads/shared-results/A_Crowncourt.json&quot;
def sharedDate = new Date().format(&apos;yyyy-MM-dd&apos;).toString()
vars.put(&quot;SHAREDDATE&quot;, sharedDate)

def orderedDate = new Date().format(&apos;yyyy-MM-dd&apos;).toString()
def jsonSlurper = new JsonSlurper()
def allDefendants = vars.getObject(&quot;DEFENDANTID_ALL&quot;).split(&apos;,&apos;)

vars.put(&quot;noOfDefendants&quot;, allDefendants.size().toString())
def prosecutionCaseDetails = jsonSlurper.parseText(vars.getObject(&quot;prosecutionCase&quot;))

def fileContent = new File(filePath).getText(&quot;UTF-8&quot;)
def currentRelList = []
def currentResLinesMap = []
def lastRelList = []
def lastResLinesMap = []
def resultLinesMapList = []
def json_9 = &quot;&quot;

allDefendants.eachWithIndex { defendantId, dInd -&gt;
    def matchedDefendant = prosecutionCaseDetails.defendants.findAll { it.id == defendantId }

    if (!matchedDefendant || !matchedDefendant.first()?.offences) {
        log.warn(&quot;No offences found for defendant: $defendantId&quot;)
        return
    }

    def allOffences = matchedDefendant.first().offences.collect { it.id }

    allOffences.eachWithIndex { offenceId, oInd -&gt;
        // Read and parse fresh JSON for each offence
        def parsedJson = new JsonSlurper().parseText(fileContent)

        // Step 1: Build binding map for placeholders
        def binding = [
            DEFENDANTID : defendantId,
            OFFENCEID   : offenceId,
            HEARINGID   : vars.get(&quot;HEARING_ID&quot;),
            HEARINGDAY  : vars.get(&quot;HEARING_DATE&quot;),
            CASEID      : vars.get(&quot;CASE_ID&quot;),
            ORDEREDDATE : orderedDate,
            FIXEDDATE   : fixedDate,
            SHAREDDATE  : sharedDate
        ]

        // Step 2: String substitute fixed placeholders like ${DEFENDANTID}, etc.
        def engine = new groovy.text.SimpleTemplateEngine()
        def template = engine.createTemplate(fileContent).make(binding)
        parsedJson = new JsonSlurper().parseText(template.toString())

        // Step 3: Collect all placeholder resultLineIds
        def placeholderIds = [] as Set
        parsedJson.relations.each { rel -&gt;
            placeholderIds &lt;&lt; rel.resultLineId
            rel.childResultLineIds?.each { placeholderIds &lt;&lt; it }
        }
        parsedJson.resultLines.each { rl -&gt;
            placeholderIds &lt;&lt; rl.resultLineId
            rl.childResultLineIds?.each { placeholderIds &lt;&lt; it }
        }

        // Step 4: Create mapping from placeholder to UUID
        def idMap = [:]
        placeholderIds.each { idMap[it] = UUID.randomUUID().toString() }

        // Step 5: Replace in relations
        parsedJson.relations.each { rel -&gt;
            rel.resultLineId = idMap[rel.resultLineId]
            rel.childResultLineIds = rel.childResultLineIds.collect { idMap[it] }
        }

        // Step 6: Replace in resultLines
        parsedJson.resultLines.each { rl -&gt;
            rl.resultLineId = idMap[rl.resultLineId]
            rl.childResultLineIds = rl.childResultLineIds.collect { idMap[it] }

            // Attach metadata
            rl.defendantId = defendantId
            rl.offenceId = offenceId
            rl.caseId = vars.get(&quot;CASE_ID&quot;)
        }

        // Collect for merge
        if (dInd == 0 &amp;&amp; oInd == 0) {
            json_9 = JsonOutput.toJson(parsedJson)
            vars.putObject(&quot;sharedResultPayload&quot;, json_9)
            lastRelList = parsedJson.relations
            lastResLinesMap = parsedJson.resultLines
        } else {
            currentRelList += parsedJson.relations
            currentResLinesMap += parsedJson.resultLines
        }

        // Add to resultLinesMapList for logging or tracking
        resultLinesMapList += parsedJson.resultLines.collect {
            [
                resultLineId: it.resultLineId,
                childResultLineIds: it.childResultLineIds,
                valid: it.valid,
                defendantId: it.defendantId,
                offenceId: it.offenceId,
                originalText: it.originalText,
                caseId: it.caseId
            ]
        }
    }
}

// ✅ Log values to verify before final merge
log.info(&quot;lastRelList: ${lastRelList?.size()}&quot;)
log.info(&quot;currentRelList: ${currentRelList?.size()}&quot;)
log.info(&quot;lastResLinesMap: ${lastResLinesMap?.size()}&quot;)
log.info(&quot;currentResLinesMap: ${currentResLinesMap?.size()}&quot;)

// ✅ Final payload merge
def mergedJson = new JsonSlurper().parseText(json_9)
mergedJson.hearingId = vars.get(&quot;HEARING_ID&quot;)
mergedJson.hearingDay = vars.get(&quot;HEARING_DATE&quot;)
mergedJson.relations = (lastRelList ?: []) + (currentRelList ?: [])
mergedJson.resultLines = (lastResLinesMap ?: []) + (currentResLinesMap ?: [])

def finalPayload = JsonOutput.prettyPrint(JsonOutput.toJson(mergedJson))
vars.put(&quot;sharedResultPayload&quot;, finalPayload)

log.info(&quot;✅ Final sharedResultPayload:\n&quot; + finalPayload)
</stringProp>
                    </JSR223Sampler>

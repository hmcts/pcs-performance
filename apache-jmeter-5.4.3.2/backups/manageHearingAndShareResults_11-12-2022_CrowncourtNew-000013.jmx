                          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">true</stringProp>
                            <stringProp name="script">//set Response Message
	SampleResult.setResponseMessage(&quot;HearingAndShareResults_v3: Unable to Share for  &quot; + vars.get(&quot;NEW_URN&quot;));
 
//set Response Data
	SampleResult.setResponseData(&quot;HearingAndShareResults_v3: Unable to Share&quot; , &quot;UTF-8&quot;); //+ vars.get(&quot;NEW_URN&quot;)

//set Response Data
	SampleResult.setResponseCode(&quot;418&quot;);

//set Failure
	SampleResult.setSuccessful(false);

//send error
 	log.error(&quot;ERROR: ShareResults ${caseType}: &quot; + vars.get(&quot;NEW_URN&quot;));


vars.put(&quot;HearingStatusNotificationPollingEnded&quot;, &quot;true&quot;);	

log.info(&quot;hearing shared results are not saved for: &quot; + vars.get(&quot;NEW_URN&quot;) + &quot;,&quot; + vars.get(&quot;HEARING_ID&quot;));

vars.put(&quot;resultshared&quot;,&quot;false&quot;);
</stringProp>

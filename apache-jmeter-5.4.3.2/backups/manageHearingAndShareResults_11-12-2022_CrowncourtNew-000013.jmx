                          <stringProp name="scriptLanguage">groovy</stringProp>
                          <stringProp name="parameters"></stringProp>
                          <stringProp name="filename"></stringProp>
                          <stringProp name="cacheKey">true</stringProp>
                          <stringProp name="script">if (vars.get(&quot;hearingIdFromSaveDraftResult&quot;).equals(vars.get(&quot;HEARING_ID&quot;))) {
	vars.put(&quot;HearingDraftResultsNotificationPollingEnded&quot;, &quot;true&quot;);
     prev.setSuccessful(true);
} else {
	current_iteration = vars.get(&quot;poolingIterationCounter&quot;);
	new_iteration_value = Integer.parseInt(current_iteration) - 1 ;
//	log.info(&quot;new iteration value  &quot; + new_iteration_value);

	if (new_iteration_value == 0){
	 vars.put(&quot;HearingDraftResultsNotificationPollingEnded&quot;, &quot;true&quot;);
	 log.error(&quot;hearing draft results are not saved for  ===&gt;  &quot; + vars.get(&quot;NEW_URN&quot;) + &quot;,&quot; + vars.get(&quot;HEARING_ID&quot;));	
      prev.setSuccessful(false);
      prev.setResponseCode(&quot;418&quot;);
	}
	vars.put(&quot;poolingIterationCounter&quot;, String.valueOf(new_iteration_value));
}
</stringProp>

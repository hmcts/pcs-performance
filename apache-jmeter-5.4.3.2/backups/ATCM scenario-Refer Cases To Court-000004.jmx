          <hashTree>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="generate SJP session details" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">vars.put(&quot;poolingIterationCounter&quot;, &quot;20&quot;);
vars.put(&quot;SessionID&quot;, UUID.randomUUID().toString());
vars.put(&quot;applicationStatusNotificationPollingEnded&quot;,&quot;false&quot;);

//Used in header CPPCLIENTCORRELATIONID for scheduling-command/start-sjp-session
vars.put(&quot;sessionCorelationID&quot;,  UUID.randomUUID().toString());
vars.put(&quot;assignCorelationID&quot;,  UUID.randomUUID().toString());

// store session_id
vars.put(&quot;session_id&quot;, UUID.randomUUID().toString());

//Set subscriptionId to empty string for the beggining of session 
vars.put(&quot;subscriptionID&quot;, &quot;&quot;);

//reset remainingSJPSessionIterations to original state -set as in UDV SJP session configuration: 
String originalIterations = vars.get(&quot;iterationsPerSJPSession&quot;);
vars.put(&quot;remainingSJPSessionIterations&quot;, originalIterations);

//Set initial value for iteration counter for events pooling - getting caseId 
String originalPoolingIterations = vars.get(&quot;InitialPoolingForNotificationEventsCounter&quot;);
vars.put(&quot;poolingIterationCounter&quot;, originalPoolingIterations);


vars.put(&quot;CASE_ID&quot;,&quot;NOT_FOUND&quot;)
vars.put(&quot;sessionStartedCheckAttempt&quot;, &quot;&quot;);
vars.put(&quot;sessionStartedCheckAttempt2&quot;,&quot;&quot;);


</stringProp>
            </JSR223Sampler>

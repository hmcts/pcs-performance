                <hashTree>
                  <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="compute caseDecision payload" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">List&lt;String&gt; offences = new ArrayList&lt;String&gt;();

for(int i=1; i&lt;=vars.get(&quot;OFFENCES_matchNr&quot;).toInteger();i++){
def offenceDecisionsPayload = &quot;{\&quot;offenceId\&quot;: \&quot;&quot;+vars.get(&quot;OFFENCES_&quot;+i)+&quot;\&quot;,\&quot;verdict\&quot;: \&quot;NO_VERDICT\&quot;}&quot;

offences.add(offenceDecisionsPayload);
def decisionPayload= offences.join(&apos;,&apos;)
vars.put(&quot;decisionsPayload&quot;,decisionPayload)

}


</stringProp>
                  </JSR223PreProcessor>
                  <hashTree/>
                  <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header manager" enabled="true">

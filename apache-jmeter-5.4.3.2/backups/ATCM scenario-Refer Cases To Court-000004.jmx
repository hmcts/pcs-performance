              <hashTree>
                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="generate SJP session details" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">vars.put(&quot;CASE_ID&quot;,&quot;NOT_FOUND&quot;)
vars.put(&quot;sessionStartedCheckAttempt&quot;, &quot;&quot;);
vars.put(&quot;sessionStartedCheckAttempt2&quot;,&quot;&quot;);
vars.put(&quot;assignCorelationID&quot;,  UUID.randomUUID().toString());
caseId = vars.get(&quot;caseId&quot;);
current_iteration = vars.get(&quot;remainingSJPSessionIterations&quot;);
new_iteration_value = Integer.parseInt(current_iteration) -1 ;
vars.put(&quot;remainingSJPSessionIterations&quot;, String.valueOf(new_iteration_value));</stringProp>
                </JSR223Sampler>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="createTemporaryVariables" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">vars.put(&quot;NEW_URN&quot;, &quot;${__Random(10, 99)}IX${__Random(1000000, 9999999)}&quot;);
String timeMillis = Long.toString(System.currentTimeMillis());
vars.put(&quot;REQUEST_ID&quot;, timeMillis + &quot;${__Random(10, 99)}&quot;);

def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
java.util.Random ran = new java.util.Random();
def tempDays  = ran.nextInt(Integer.parseInt(vars.get(&quot;hearingRandomDays&quot;))) + 2;
def hDate = java.time.LocalDateTime.now().plusDays(tempDays).format(DATETIME_FORMAT);

def weekDate = java.time.LocalDate.parse(hDate);
if(weekDate.getDayOfWeek() == java.time.DayOfWeek.SATURDAY)  {
            weekDate = weekDate.plusDays(2);  }
 else if(weekDate.getDayOfWeek() == java.time.DayOfWeek.SUNDAY) {
 	 	 weekDate = weekDate.plusDays(1);  }

vars.put(&quot;HEARING_DATE&quot;, weekDate.format(DATETIME_FORMAT)); 

def faker = new com.github.javafaker.Faker();
vars.put(&quot;defendantFirstName1&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName1&quot;, faker.name().lastName());
vars.put(&quot;streetAddress1&quot;, faker.address().streetAddress());
vars.put(&quot;DOB1&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName2&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName2&quot;, faker.name().lastName());
vars.put(&quot;streetAddress2&quot;, faker.address().streetAddress());
vars.put(&quot;DOB2&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName3&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName3&quot;, faker.name().lastName());
vars.put(&quot;streetAddress3&quot;, faker.address().streetAddress());
vars.put(&quot;DOB3&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName4&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName4&quot;, faker.name().lastName());
vars.put(&quot;streetAddress4&quot;, faker.address().streetAddress());
vars.put(&quot;DOB4&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName5&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName5&quot;, faker.name().lastName());
vars.put(&quot;streetAddress5&quot;, faker.address().streetAddress());
vars.put(&quot;DOB5&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName6&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName6&quot;, faker.name().lastName());
vars.put(&quot;streetAddress6&quot;, faker.address().streetAddress());
vars.put(&quot;DOB6&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName7&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName7&quot;, faker.name().lastName());
vars.put(&quot;streetAddress7&quot;, faker.address().streetAddress());
vars.put(&quot;DOB7&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName8&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName8&quot;, faker.name().lastName());
vars.put(&quot;streetAddress8&quot;, faker.address().streetAddress());
vars.put(&quot;DOB8&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName9&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName9&quot;, faker.name().lastName());
vars.put(&quot;streetAddress9&quot;, faker.address().streetAddress());
vars.put(&quot;DOB9&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);

vars.put(&quot;defendantFirstName10&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName10&quot;, faker.name().lastName());
vars.put(&quot;streetAddress10&quot;, faker.address().streetAddress());
vars.put(&quot;DOB10&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);


for(i = 0 ; i &lt; 50 ; i++ ) {
def allOffencesCodes = props.get(&quot;ALL_OFFENCE_CODES&quot;);
random_num = ran.nextInt(allOffencesCodes.size())
def randomOffenceDetails = allOffencesCodes.get(random_num).split(&quot;,&quot;);
vars.put(&quot;offenceCode_&quot; + i , randomOffenceDetails.first());
vars.put(&quot;offenceDescription_&quot; + i, randomOffenceDetails.last()); 
}

def randomDay  = ${__Random(1,99,)}; 
def offenceStartDate = weekDate.minusYears(2).minusDays(randomDay);
def offenceArrestDate = offenceStartDate.plusMonths(1);

vars.put(&quot;offenceStartDate&quot;, offenceStartDate.format(DATETIME_FORMAT));
vars.put(&quot;offenceArrestDate&quot;, offenceArrestDate.format(DATETIME_FORMAT));


</stringProp>
        </JSR223Sampler>

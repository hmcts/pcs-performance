            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import  org.apache.commons.lang3.*;

class UrnGenerator {

    def randomNumber(lowerLimit, upperLimit) {
        Math.abs(new Random().nextInt() % ([upperLimit] - [lowerLimit])) + [lowerLimit]
    }

    def randomNumbering(int number) {
    	org.apache.commons.lang3.RandomStringUtils.randomNumeric(number);
    }

    def newUrn() {
    	//+ randomNumber(10, 99) + &quot;XD&quot;
        &quot;CV&quot;  + randomNumber(1000000, 9999999)
    }

  //org.apache.commons.lang3.RandomStringUtils.random(1, 1, 9, false, true)
    def pncIdentifier() {
    randomNumber(1, 9) + this.randomNumbering(3) + &quot;/&quot; + this.randomNumbering(7) + org.apache.commons.lang3.RandomStringUtils.randomAlphabetic(1);
	}

	def croNumber() {
     this.randomNumbering(6) + &quot;/&quot; + this.randomNumbering(2) + this.randomNumbering(1);
	}

//    def pncIdentifier() {
//        randomNumber(0000, 3333) + &quot;/&quot; + randomNumber(100000, 999999) + &quot;L&quot;
//    }
//
//    def croNumber() {
//        randomNumber(000000, 333333) + &quot;/&quot; + randomNumber(10, 99) + &quot;L&quot;
//
//    }
}


class ListRandomizer {
	def static get(ArrayList list) {
	   def ran = new Random();     
        def randomNumber = ran.nextInt(list.size());
        list[randomNumber];
}

}

class RandomPostCode {
//DEPRECATED
    def generate() {
        def listOfPostCodes = [&quot;CR0 1EB&quot;, &quot;B69 9EL&quot;, &quot;CH49 0XE&quot;, &quot;OX15 6BG&quot;, &quot;PO9 5JZ&quot;, &quot;EX4 3FP&quot;, &quot;HX4 0AD&quot;, &quot;HP22 5SS&quot;, &quot;B24 0HT&quot;, &quot;CH4 8BB&quot;, &quot;L18 4PS&quot;, &quot;B30 1RT&quot;, &quot;LE4 2DR&quot;, &quot;TW5 9BD&quot;, &quot;LE3 6QP&quot;, &quot;G41 2RU&quot;, &quot;DY8 1EZ&quot;, &quot;DL5 7EP&quot;, &quot;WA1 2HS&quot;, &quot;CT14 9JW&quot;, &quot;DH1 3SQ&quot;, &quot;CF14 9HD&quot;, &quot;SW4 9BA&quot;, &quot;DT11 7FN&quot;, &quot;NG11 9GY&quot;, &quot;TN5 6JQ&quot;, &quot;BH15 1RT&quot;, &quot;LA14 2DB&quot;, &quot;KY12 8LN&quot;, &quot;WA4 6NY&quot;, &quot;RH13 9DU&quot;];
        ListRandomizer.get(listOfPostCodes);
    }
}


class RandomGender {
    def int generate() {
    	ListRandomizer.get([0, 1])
    }
}

class RandomCaseMaker {
    def generate() {
        def caseMarkerList = [&quot;FT&quot;, &quot;RP&quot;, &quot;FM&quot;, &quot;CO&quot;, &quot;TG&quot;, &quot;SC&quot;, &quot;CW&quot;, &quot;DH&quot;, &quot;HT&quot;, &quot;AR&quot;];
        ListRandomizer.get(caseMarkerList);
    }
}

class RandomInformant {
    def generate() {
        def InformantList = [&quot;ADAM&quot;, &quot;RICKEY&quot;, &quot;BEN&quot;, &quot;JOHN&quot;, &quot;ELISA&quot;, &quot;LEO&quot;, &quot;MICH&quot;, &quot;LAD&quot;, &quot;HILTON&quot;, &quot;STONE&quot;];
        ListRandomizer.get(InformantList);
    }
}

class RandomTitle {
	def generate() {
        def titlesList = [&quot;Mr&quot;, &quot;Mrs&quot;, &quot;Ms&quot;, &quot;Miss&quot;];
        ListRandomizer.get(titlesList);
    }
	
}


class DateBuilder {
    def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
    def randomDay = new UrnGenerator().randomNumber(20, 200);
        
    def hearingDate() {
        java.util.Random ran = new java.util.Random();
        def tempDays = ran.nextInt(20 + 2);
        def hDate = java.time.LocalDateTime.now().plusDays(tempDays).format(DATETIME_FORMAT);
        def weekDate = java.time.LocalDate.parse(hDate);
        if (weekDate.getDayOfWeek() == java.time.DayOfWeek.SATURDAY) {
            weekDate = weekDate.plusDays(2);
        } else if (weekDate.getDayOfWeek() == java.time.DayOfWeek.SUNDAY) {
            weekDate = weekDate.plusDays(1);
        }
        weekDate.format(DATETIME_FORMAT);
    }

    def dateOfBirth() {
        def randomAgeNo = new UrnGenerator().randomNumber(20, 80);
        java.time.LocalDateTime.now().minusYears(randomAgeNo).format(DATETIME_FORMAT);
    }

    def List offenceDate() {

        def offenceStartDate = java.time.LocalDateTime.now().minusDays(randomDay).format(DATETIME_FORMAT).toString();
        def offenceEndDate = java.time.LocalDateTime.now().minusDays(randomDay + 1).format(DATETIME_FORMAT).toString();
        [offenceStartDate, offenceEndDate]
    }

	def offenceArrestDate() {
		java.time.LocalDateTime.now().minusDays(randomDay - 21).format(DATETIME_FORMAT).toString();
	}
	

    def List backDutyDate() {
        def randomDay = new UrnGenerator().randomNumber(100, 300);
        def backDutyStartDate = java.time.LocalDateTime.now().minusDays(randomDay).format(DATETIME_FORMAT).toString();
        def backDutyEndDate = java.time.LocalDateTime.now().minusDays(randomDay + 1).format(DATETIME_FORMAT).toString();
        [backDutyStartDate, backDutyEndDate]
    }


}

class RamdonEthnicity {

    def generate() {
        def ethnicityList = [&quot;W1&quot;, &quot;W2&quot;];
        ListRandomizer.get(ethnicityList);
    }
}


class VehicleNumber {

    def randomString(size) {
        org.apache.commons.lang3.RandomStringUtils.randomAlphanumeric(size).toUpperCase();
    }

    def generate() {
        this.randomString(2) + new UrnGenerator().randomNumber(10, 20) + &quot; &quot; + this.randomString(3)
    }

}



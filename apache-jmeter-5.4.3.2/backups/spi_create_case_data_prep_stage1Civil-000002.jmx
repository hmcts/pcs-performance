        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__P(SPI_CASES_DEFENCE_TARGET_THREADS,5)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${__P(SPI_CASES_DEFENCE_UP_TIME,1)}</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">900</stringProp>
        <stringProp name="ThreadGroup.delay">60</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>

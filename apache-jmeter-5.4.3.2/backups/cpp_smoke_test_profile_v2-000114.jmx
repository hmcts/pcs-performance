          <stringProp name="script">FileWriter fWriter = new FileWriter(vars.get(&quot;expDir&quot;) + &quot;BurnedData_URNS&quot;  + vars.get(&quot;todaysTimestamp&quot;) + &quot;.csv&quot;, true);

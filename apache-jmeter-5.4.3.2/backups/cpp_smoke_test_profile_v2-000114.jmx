          <stringProp name="script">//log.info(&quot;XYZ: &quot; + props.get(&quot;legalAdvisorsCsvDatapath&quot;));

vars.put(&quot;SCENARIO_NAME&quot;,ctx.getThreadGroup().getName().toString())

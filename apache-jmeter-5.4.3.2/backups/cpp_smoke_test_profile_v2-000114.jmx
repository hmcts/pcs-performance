        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="ALLOCATE_HEARING_OUTPUT" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">FileWriter fWriter = new FileWriter(vars.get(&quot;expDir&quot;) + &quot;allocated_hearing_output.csv&quot;, true);
BufferedWriter buff = new BufferedWriter(fWriter);

String COURT_ROOM = vars.get(&quot;COURT_ROOM&quot;);
String OUCODE = vars.get(&quot;OUCODE&quot;);
String listingAllocatePayload = vars.get(&quot;listingAllocatePayload&quot;);
String caseDetails = COURT_ROOM + &quot;,&quot; + OUCODE + &quot;,&quot; + listingAllocatePayload;

buff.write(caseDetails + &quot;\r\n&quot;);
buff.close();
fWriter.close();


//log.info(&quot;*****&quot; + vars.get(&quot;expDir&quot;) + &quot;\\output\\allocated_hearing_output.csv&quot; + &quot;*****&quot;);
//log.info(&quot;allocated cases without material &quot; + caseDetails);


</stringProp>

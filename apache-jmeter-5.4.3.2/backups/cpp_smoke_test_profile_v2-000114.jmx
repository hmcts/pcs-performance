              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="script">vars.put(&quot;NEW_URN&quot;, &quot;${__Random(10, 99)}PT${__Random(1000000, 9999999)}&quot;);

def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
java.util.Random ran = new java.util.Random();
def tempDays  = ran.nextInt(Integer.parseInt(vars.get(&quot;hearingRandomDays&quot;))) + 2;
def hDate = java.time.LocalDateTime.now().plusDays(tempDays).format(DATETIME_FORMAT);

def weekDate = java.time.LocalDate.parse(hDate);

if(weekDate.getDayOfWeek() == java.time.DayOfWeek.SATURDAY)  {
            weekDate = weekDate.plusDays(2);  }
 else if(weekDate.getDayOfWeek() == java.time.DayOfWeek.SUNDAY) {
 	 	 weekDate = weekDate.plusDays(1);  }

def hearingDate = weekDate.format(DATETIME_FORMAT);
log.info(&quot;hearing_date &quot; +  hearingDate ) ;
vars.put(&quot;HEARING_DATE&quot;, hearingDate); 


vars.put(&quot;DOB1&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);
String timeMillis = Long.toString(System.currentTimeMillis());
vars.put(&quot;REQUEST_ID&quot;, timeMillis + &quot;${__Random(10, 99)}&quot;);

def faker = new com.github.javafaker.Faker();
vars.put(&quot;defendantFirstName&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName&quot;, faker.name().lastName());
vars.put(&quot;streetAddress&quot;, faker.address().streetAddress());

def allOffencesCodes = props.get(&quot;ALL_OFFENCE_CODES&quot;);
random_num = ran.nextInt(allOffencesCodes.size())
def randomOffenceDetails = allOffencesCodes.get(random_num).split(&quot;,&quot;);
vars.put(&quot;offenceCode&quot; , randomOffenceDetails.first());
vars.put(&quot;offenceDescription&quot;, randomOffenceDetails.last()); 

def randomDay  = ${__Random(1,99,)}; 
def offenceStartDate = weekDate.minusYears(2).minusDays(randomDay);
def offenceArrestDate = offenceStartDate.plusMonths(1);

vars.put(&quot;offenceStartDate&quot;, offenceStartDate.format(DATETIME_FORMAT));
vars.put(&quot;offenceArrestDate&quot;, offenceArrestDate.format(DATETIME_FORMAT));

log.info(&quot;REQUEST_ID:&quot; + vars.get(&quot;REQUEST_ID&quot;));
log.info(&quot;destinationID:&quot; + vars.get(&quot;destinationID&quot;));

log.info(&quot;NEW_URN:&quot; + vars.get(&quot;NEW_URN&quot;));
log.info(&quot;originatingOrganisation:&quot; + vars.get(&quot;originatingOrganisation&quot;));
log.info(&quot;courtHearingLocation:&quot; + vars.get(&quot;courtHearingLocation&quot;));
log.info(&quot;HEARING_DATE:&quot; + vars.get(&quot;HEARING_DATE&quot;));
log.info(&quot;prosecutorReference:&quot; + vars.get(&quot;prosecutorReference&quot;));
log.info(&quot;defendantFirstName:&quot; + vars.get(&quot;defendantFirstName&quot;));
log.info(&quot;defendantLastName:&quot; + vars.get(&quot;defendantLastName&quot;));
log.info(&quot;DOB:&quot; + vars.get(&quot;DOB1&quot;));
log.info(&quot;streetAddress:&quot; + vars.get(&quot;streetAddress&quot;));
log.info(&quot;offenceCode:&quot; + vars.get(&quot;offenceCode&quot;));
log.info(&quot;offenceDescription:&quot; + vars.get(&quot;offenceDescription&quot;));
log.info(&quot;offenceStartDate:&quot; + vars.get(&quot;offenceStartDate&quot;));
log.info(&quot;offenceStartDate:&quot; + vars.get(&quot;offenceStartDate&quot;));
log.info(&quot;offenceArrestDate:&quot; + vars.get(&quot;offenceArrestDate&quot;));






                <stringProp name="script">def path  = vars.get(&quot;expDir&quot;) + &apos;material_db_count.log&apos;;

	FileWriter fWriter = new FileWriter(path, true);
	BufferedWriter buff = new BufferedWriter(fWriter);
	String todaysDate = &quot;${__time(yyyy-MM-dd HH:mm:ss)}&quot;;


	buff.write(&quot;pre_publish_queue_count,&quot; + todaysDate + &quot;,&quot; + vars.get(&quot;pre_publish_queue_count_#&quot;) + &quot;,publish_queue_count,&quot; + todaysDate + &quot;,&quot; + vars.get(&quot;publish_queue_count_#&quot;) + &quot;\r\n&quot;);


	buff.close();
	fWriter.close();
</stringProp>

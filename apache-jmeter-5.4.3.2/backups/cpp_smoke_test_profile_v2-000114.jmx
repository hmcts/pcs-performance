          <stringProp name="script">import org.apache.commons.io.FileUtils;   
import org.apache.jmeter.services.FileServer

def getRandomRowFromCsv() {
	def inputPath = FileServer.getFileServer().getBaseDir() + &quot;/spi/data/offenceCodes.csv&quot;;
     List csvData = FileUtils.readLines(new File(inputPath));
     return csvData
}
props.put(&quot;ALL_OFFENCE_CODES&quot;, getRandomRowFromCsv());

log.info(&quot;ALL_OFFENCE_CODES: &quot; + props.get(&quot;ALL_OFFENCE_CODES&quot;));


def location = vars.get(&quot;courtHearingUnallocatedLocation&quot;);
def roomCode =  vars.get(&quot;courtroomCode&quot;);
def courtLocation = location.substring(0,5) + roomCode;
vars.put(&quot;courtHearingLocation&quot;, courtLocation);

vars.put(&quot;SCENARIO_NAME&quot;,ctx.getThreadGroup().getName().toString())</stringProp>

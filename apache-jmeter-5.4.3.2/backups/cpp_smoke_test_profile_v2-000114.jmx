          <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="printCaseInfo" enabled="false">
            <stringProp name="BeanShellSampler.query"> String location = vars.get(&quot;courtHearingUnallocatedLocation&quot;);
 String caseUrn = vars.get(&quot;NEW_URN&quot;);
 String courtCenter = vars.get(&quot;COURT_CENTRE&quot;);
 String courtRoom = vars.get(&quot;COURT_ROOM&quot;);
 String hearingDate = vars.get(&quot;HEARING_DATE&quot;);
 String caseDetails = caseUrn + &quot;,&quot; + hearingDate + &quot;,&quot; + courtCenter + &quot;,&quot; +  courtRoom + &quot;,&quot; +  &quot;1D-1O&quot;; 
 vars.put(&quot;idbc_file_name&quot;, &quot;smallPDF.txt&quot;);
 log.info(&quot;CaseDetails &quot; + caseDetails);

 vars.put(&quot;INPUT_DATA&quot;,caseDetails)



</stringProp>

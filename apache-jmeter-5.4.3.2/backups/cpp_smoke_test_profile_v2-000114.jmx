        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="setFilePaths" enabled="true">
          <stringProp name="TestPlan.comments">this sets dynamically csv path based on no of slaves</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.jmeter.services.FileServer



def basePath  = FileServer.getFileServer().getBaseDir() + &quot;/shared/data/&quot;+ vars.get(&quot;envType&quot;);

def administratorCsvDatapath = basePath + &quot;/unprocessedUnallocatedCaseURNsForAdminstrators.csv&quot;;
def legalAdvisorsCsvDatapath = basePath + &quot;/unprocessedAllocatedCaseURNsForLegalAdvisors.csv&quot; 
def legalAdvisorsWelshCsvDatapath = basePath + &quot;/unprocessedAllocatedCaseURNsForLegalAdvisors_welsh.csv&quot; 
def legalAdvisorsLargeCaseCsvDatapath = basePath + &quot;/unprocessedAllocatedCaseURNsForLegalAdvisors_largecase.csv&quot;          
def legalAdvisorsNotSharedCsvDatapath = basePath + &quot;/unprocessedAllocatedCaseURNsForLegalAdvisorsNotShared.csv&quot; 
def legalAdvisorsEjectCsvDatapath = basePath + &quot;/unallocatedCasesForEjectFromCPP.csv&quot;          
def courtAssociatesCsvDatapath  = basePath + &quot;/unprocessedAllocatedCaseURNsForCourtAssociates.csv&quot;        
def courtClerksCsvDatapath  = basePath + &quot;/unprocessedAllocatedCaseURNsForCourtClerks.csv&quot;            
def defenceComplexCsvDatapath  = basePath + &quot;/unprocessedCaseURNsForDefenceComplex.csv&quot; 
def youthOffendingServiceUsersCsvDatapath  = basePath + &quot;/allocatedCaseURNsForYouthOffendingServiceUsers.csv&quot;                 
def cPSUsersCsvDatapath = basePath + &quot;/allocatedCaseURNsForCPSUsers.csv&quot;                                                   
def probationUsersCsvDatapath  = basePath + &quot;/allocatedCaseURNsForProbationUsers.csv&quot;                    
def lAAUsersCsvDatapath  = basePath + &quot;/allocatedCasesForLAAUsers.csv&quot;                             
def djmcUsersCsvDatapath = basePath + &quot;/allocatedCasesForDjmcUsers.csv&quot;                            
def applicationsCsvDatapath  = basePath + &quot;/unprocessedAllocatedCaseURNsForApplications.csv&quot;           
def resultingApplicationsCsvDatapath = basePath + &quot;/unprocessedAllocatedCaseURNsForResultingApplications.csv&quot;
def LAARepresentationOrderCsvDatapath  = basePath + &quot;/LAARepresentationOrder.csv&quot;   

if(vars.get(&quot;slaveSuffix&quot;) != &quot;&quot;) {
administratorCsvDatapath = administratorCsvDatapath + vars.get(&quot;slaveSuffix&quot;);       
legalAdvisorsCsvDatapath = legalAdvisorsCsvDatapath + vars.get(&quot;slaveSuffix&quot;); 
legalAdvisorsWelshCsvDatapath = legalAdvisorsWelshCsvDatapath + vars.get(&quot;slaveSuffix&quot;);
legalAdvisorsLargeCaseCsvDatapath = legalAdvisorsLargeCaseCsvDatapath + vars.get(&quot;slaveSuffix&quot;);        
legalAdvisorsNotSharedCsvDatapath = legalAdvisorsNotSharedCsvDatapath + vars.get(&quot;slaveSuffix&quot;); 
legalAdvisorsEjectCsvDatapath = legalAdvisorsEjectCsvDatapath + vars.get(&quot;slaveSuffix&quot;);
courtAssociatesCsvDatapath = courtAssociatesCsvDatapath + vars.get(&quot;slaveSuffix&quot;);       
courtClerksCsvDatapath = courtClerksCsvDatapath + vars.get(&quot;slaveSuffix&quot;);           
defenceComplexCsvDatapath = defenceComplexCsvDatapath + vars.get(&quot;slaveSuffix&quot;);        
cPSUsersCsvDatapath = cPSUsersCsvDatapath + vars.get(&quot;slaveSuffix&quot;);             
probationUsersCsvDatapath = probationUsersCsvDatapath + vars.get(&quot;slaveSuffix&quot;);        
lAAUsersCsvDatapath = lAAUsersCsvDatapath + vars.get(&quot;slaveSuffix&quot;);             
djmcUsersCsvDatapath = djmcUsersCsvDatapath + vars.get(&quot;slaveSuffix&quot;);              
applicationsCsvDatapath = applicationsCsvDatapath + vars.get(&quot;slaveSuffix&quot;);            
resultingApplicationsCsvDatapath = resultingApplicationsCsvDatapath + vars.get(&quot;slaveSuffix&quot;); 
youthOffendingServiceUsersCsvDatapath = youthOffendingServiceUsersCsvDatapath + vars.get(&quot;slaveSuffix&quot;);
LAARepresentationOrderCsvDatapath = LAARepresentationOrderCsvDatapath + vars.get(&quot;slaveSuffix&quot;);   

}

props.put(&quot;administratorCsvDatapath&quot;, administratorCsvDatapath);
props.put(&quot;legalAdvisorsEjectCsvDatapath&quot;,legalAdvisorsEjectCsvDatapath);
props.put(&quot;legalAdvisorsCsvDatapath&quot;,legalAdvisorsCsvDatapath)   
props.put(&quot;legalAdvisorsWelshCsvDatapath&quot;,legalAdvisorsWelshCsvDatapath);
props.put(&quot;legalAdvisorsLargeCaseCsvDatapath&quot;,legalAdvisorsLargeCaseCsvDatapath);      
props.put(&quot;legalAdvisorsNotSharedCsvDatapath&quot;,legalAdvisorsNotSharedCsvDatapath)
props.put(&quot;courtAssociatesCsvDatapath&quot;,courtAssociatesCsvDatapath)       
props.put(&quot;courtClerksCsvDatapath&quot;,courtClerksCsvDatapath)           
props.put(&quot;defenceComplexCsvDatapath&quot;,defenceComplexCsvDatapath)        
props.put(&quot;cPSUsersCsvDatapath&quot;,cPSUsersCsvDatapath)              
props.put(&quot;probationUsersCsvDatapath&quot;,probationUsersCsvDatapath)        
props.put(&quot;lAAUsersCsvDatapath&quot;,lAAUsersCsvDatapath)              
props.put(&quot;djmcUsersCsvDatapath&quot;,djmcUsersCsvDatapath)             
props.put(&quot;applicationsCsvDatapath&quot;,applicationsCsvDatapath)          
props.put(&quot;resultingApplicationsCsvDatapath&quot;,resultingApplicationsCsvDatapath) 
props.put(&quot;youthOffendingServiceUsersCsvDatapath&quot;,youthOffendingServiceUsersCsvDatapath)
props.put(&quot;LAARepresentationOrderCsvDatapath&quot;,LAARepresentationOrderCsvDatapath) 

 
</stringProp>

            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SharedKeyLite AuthorizationHeader Generator" enabled="true">
              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import javax.crypto.Mac;
import javax.crypto.spec.SecretKeySpec;
import java.security.InvalidKeyException;
import java.time.*
import groovy.json.StringEscapeUtils
import org.apache.commons.codec.binary.*


//secret key operations
def secretKey = &apos;8n5glO55KzZF9mIIkgzs6jIHtrr4vxio96dTCdop9FXnyYBUbjFzZ2EEEumY9G3tCNtOsPi6KejE+ASte8kLqQ==&apos;
def decodedSecretKey = Base64.decodeBase64(secretKey);
decodedSecretKey = Hex.encodeHexString(decodedSecretKey);
//log.info(decodedSecretKey);

//payload operations
//def myString = &apos;Thu%2C%2018%20Aug%202022%2013%3A06%3A40%20GMT%0A%2Ftestnftaccount%2Fdataprepdemo&apos;;

def date = new Date()
def time = date.format(&apos;E, dd MMM YYYY HH:mm:ss&apos;, TimeZone.getTimeZone(&apos;UTC&apos;)) + &apos; GMT&apos;;
//log.info(&quot;time: &quot; + time);
vars.put(&quot;Date&quot;, time);


//final storageAccount = &quot;testnftaccount&quot;
//final secretKey = &quot;8n5glO55KzZF9mIIkgzs6jIHtrr4vxio96dTCdop9FXnyYBUbjFzZ2EEEumY9G3tCNtOsPi6KejE+ASte8kLqQ==&quot;

//def myString = &apos;Thu, 18 Aug 2022 13:10:07 GMT\n/testnftaccount/dataprepdemo&apos;;

def myString = time + &quot;\n&quot; + &quot;/testnftaccount/&quot; + vars.get(&quot;TableName&quot;);
//log.info(myString);


byte[] secretByteArray = Base64.decodeBase64(secretKey)
Mac sha256_HMAC = Mac.getInstance(&quot;HmacSHA256&quot;);
SecretKeySpec secret_Key = new SecretKeySpec(secretByteArray, &quot;HmacSHA256&quot;);
sha256_HMAC.init(secret_Key);


def digest = sha256_HMAC.doFinal(myString.getBytes())
//log.info(digest.encodeBase64().toString());

//def hash = hmac_sha256(secretKey, &quot;Hello World&quot;)

authorizationHeader = digest.encodeBase64().toString()
//log.info(authorizationHeader)
vars.put(&quot;AuthorizationHeader&quot;, authorizationHeader);</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>

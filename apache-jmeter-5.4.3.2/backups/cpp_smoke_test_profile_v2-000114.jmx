          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">FileWriter fWriter = new FileWriter(vars.get(&quot;expDir&quot;) + &quot;BurnedData_URNS&quot;  + vars.get(&quot;todaysTimestamp&quot;) + &quot;.csv&quot;, true);
BufferedWriter buff = new BufferedWriter(fWriter);

buff.write(&quot;From &quot; + props.get(&quot;lAAUsersCsvDatapath&quot;) + &quot;, remove &quot; + vars.get(&quot;NEW_URN&quot;) + &quot;\r\n&quot;);
buff.close();
fWriter.close();


//log.info(&quot;*****&quot; + vars.get(&quot;expDir&quot;) + &quot;\\output\\allocated_hearing_output.csv&quot; + &quot;*****&quot;);
//log.info(&quot;allocated cases without material &quot; + caseDetails);


</stringProp>

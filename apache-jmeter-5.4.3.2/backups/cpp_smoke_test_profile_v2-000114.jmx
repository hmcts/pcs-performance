        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="setLocalVariables" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">/*vars.put(&quot;SCENARIO_NAME&quot;,ctx.getThreadGroup().getName().toString());
vars.put(&quot;USER&quot;, &quot;OTHER&quot;);
vars.put(&quot;resultCode&quot;,&quot;RI&quot;);*/

// Get current iteration from a variable, or default to 0
def count = vars.get(&quot;myCounter&quot;) as Integer ?: 0

// Increment
count++

// Store back
vars.put(&quot;myCounter&quot;, count.toString())


// Alternate resultCode between &quot;RI&quot; and &quot;RN&quot;
def resultCode = (count % 2 == 0) ? &quot;CCII&quot; : &quot;CCQB&quot;

// Set variables
vars.put(&quot;SCENARIO_NAME&quot;, ctx.getThreadGroup().getName().toString())
vars.put(&quot;USER&quot;, &quot;OTHER&quot;)
vars.put(&quot;resultCode&quot;, resultCode)

// Optional logging
log.info(&quot;Iteration: ${iteration} -&gt; resultCode: ${resultCode}&quot;)

</stringProp>

          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">FileWriter fWriter = new FileWriter(vars.get(&quot;expDir&quot;) + &quot;BurnedData_URNS&quot;  + vars.get(&quot;todaysTimestamp&quot;) + &quot;.csv&quot;, true);
BufferedWriter buff = new BufferedWriter(fWriter);

buff.write(&quot;From &quot; + props.get(&quot;administratorCsvDatapath&quot;) + &quot;, remove &quot; + vars.get(&quot;NEW_URN&quot;) + &quot;\r\n&quot;);
buff.close();
fWriter.close();



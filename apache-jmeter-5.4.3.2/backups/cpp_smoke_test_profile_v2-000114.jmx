          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor - Iteration Pacing" enabled="true">
              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import groovy.time.*

//Sets the pacing length based on the last requests response time. 45000 is the time in ms 
//This can be sent as an environment variable

log.info(&quot;iterationStart:&quot; + vars.get(&quot;iterationStart&quot;));
log.info(&quot;iterationEnd:&quot; + vars.get(&quot;iterationEnd&quot;));


//Long pDuration = Long.ValueOf(System.getenv(&apos;iterationPacing&apos;))
Long pDuration = Long.valueOf(vars.get(&apos;iterationPacing&apos;));

//Calculate total duration between 1st step and Last with a pre- and post- processor to log the values
TimeDuration duration =  groovy.time.TimeCategory.minus(new Date(vars.getObject(&apos;iterationEnd&apos;)), new Date(vars.getObject(&apos;iterationStart&apos;)));
vars.putObject(&apos;iterationDiff&apos;, duration.toMilliseconds());

//Calculate the wait
Long iterationDiff = Long.valueOf(vars.get(&apos;iterationDiff&apos;));
log.info(&quot;iterationDiff:&quot; + vars.get(&quot;iterationDiff&quot;));

Long pacing = pDuration - iterationDiff;

//logging everything for debugging and tracability
log.info(&quot;duration:&quot; + duration.toMilliseconds());
log.info(&quot;iterationPacing:&quot; + vars.get(&quot;iterationPacing&quot;));


//If the response time is less than 45000 ms, set the delay value to myDelay
if (pacing &gt; 0)
{
//iPacing is equal to the int value of pacing if pacing is not equal to null, otherwise iPacing is null
	Integer iPacing = pacing != null ? pacing.intValue() : null;
	log.info(&quot;Waiting:&quot; + String.valueOf(iPacing));
	vars.put(&quot;myDelay&quot;, String.valueOf(iPacing));

//	vars.put(&quot;myDelay&quot;, String.valueOf(pacing));
//	return iPacing;
}
//The response time is greater than or equal to 4500 ms, set myDelay to 0
else
{
	vars.put(&quot;myDelay&quot;, &quot;0&quot;);
	log.info(&quot;Waiting:&quot; + vars.get(&quot;myDelay&quot;));
//	return 0;
}
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>

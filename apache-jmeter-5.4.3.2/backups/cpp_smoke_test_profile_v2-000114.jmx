            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="TestPlan.comments">/*
 * Because there are potentally/probably more than one NOW file present, we can&apos;t use an extractor as standard. 
 * We&apos;ll have to write a java extractor in code and run it in a loop. 
 * 
 * Or we could just do a text check for the various file names we expect to confirm they appear somewhere in ALL of the response. 
*/</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper;

def jsonSlurper = new JsonSlurper();

log.info(&quot;payload: &quot; + vars.get(&quot;payload&quot;));
log.info(&quot;payload_#: &quot; + vars.get(&quot;payload_#&quot;));

int match = Integer.parseInt(vars.get(&quot;payload_#&quot;));
vars.put(&quot;orderName_output&quot;, &quot;&quot;);

for (i=0;i&lt;match;i++)
{
	columnValue = vars.getObject(&quot;resultObject&quot;).get(i).get(&quot;payload&quot;);
	log.info(&quot;columnValue: &quot; + columnValue);

	def orderName = jsonSlurper.parseText(columnValue).nowContent.orderName;
	log.info(&quot;orderName: &quot; + orderName);

	def orderName_output = vars.get(&quot;orderName_output&quot;);
	orderName_output = orderName_output + &quot;,&quot; + orderName;
	vars.put(&quot;orderName_output&quot;, orderName_output);

}
//log.info(&quot;orderName: &quot; + vars.get(&quot;orderName&quot;));

def path  = vars.get(&quot;expDir&quot;) + &apos;NOW_count.log&apos;;

	FileWriter fWriter = new FileWriter(path, true);
	BufferedWriter buff = new BufferedWriter(fWriter);
	String todaysDate = &quot;${__time(yyyy-MM-dd HH:mm:ss)}&quot;;


	buff.write(todaysDate + &quot;,&quot; + vars.get(&quot;NEW_URN&quot;) + &quot;,&quot; + match  + &quot;,&quot; + vars.get(&quot;orderName_output&quot;) +  &quot;\r\n&quot;);


	buff.close();
	fWriter.close();
</stringProp>
            </JSR223PostProcessor>

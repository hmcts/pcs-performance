        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="constructPayloadForBulkCivilCases" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import groovy.json.JsonBuilder;
import groovy.json.JsonSlurper;
import groovy.json.JsonOutput
import java.util.Random;
import java.util.Locale;
def payloadBuilder = new JsonBuilder()

def faker = new com.github.javafaker.Faker(Locale.UK);
def jsonSlurper = new JsonSlurper();
def count = Integer.parseInt(vars.get(&quot;NoOfCases&quot;));

//postcode
java.util.Random ran = new java.util.Random();

def allInCodes = props.get(&quot;ALL_IN_CODES&quot;);
random_num = ran.nextInt(allInCodes.size())
def randomInCode = allInCodes.get(random_num); //.split(&quot;,&quot;);

def allOutCodes = props.get(&quot;ALL_OUT_CODES&quot;);
random_num = ran.nextInt(allOutCodes.size())
def randomOutCode = allOutCodes.get(random_num); //.split(&quot;,&quot;);

def randomInDetails = randomOutCode + &quot; &quot; + randomInCode;

payloadBuilder{
  prosecutingAuthority &quot;GAEAA01&quot;
  hearingDetails {
//    courtHearingLocation vars.get(&quot;courtHearingLocation&quot;);
	courtHearingLocation &quot;B01LY01&quot;
	dateOfHearing vars.getObject(&quot;dateBuilderObj&quot;).hearingDate()
	timeOfHearing &quot;17:00:01.001&quot;
	//timeOfHearing java.time.LocalDateTime.now().toLocalTime().toString()
  }
  prosecutionCases((1..count).collect {({
  	def ethnicityValue = vars.getObject(&quot;ethnicityObj&quot;).generate()
  	def dateOfBirthValue = vars.getObject(&quot;dateBuilderObj&quot;).dateOfBirth()
  	def offenceDates = vars.getObject(&quot;dateBuilderObj&quot;).offenceDate()
     def backDutyDates = vars.getObject(&quot;dateBuilderObj&quot;).backDutyDate()
  	
      informant vars.getObject(&quot;randomInformantObj&quot;).generate() //&quot;informant&quot;: &quot;Adam&quot; //
      caseMarker vars.getObject(&quot;randomCaseMakerObj&quot;).generate() //&quot;AR&quot; //
      urn vars.getObject(&quot;urnObj&quot;).newUrn().toString()
      defendants([{
          defendantDetails {
            prosecutorDefendantId UUID.randomUUID().toString()
            asn &quot;SummonsNumber&quot; + faker.number().numberBetween(1000,400000) 
            pncIdentifier vars.getObject(&quot;urnObj&quot;).pncIdentifier()
            croNumber vars.getObject(&quot;urnObj&quot;).croNumber()
            documentationLanguage &quot;E&quot;
            hearingLanguage &quot;E&quot;
            address {
              address1 faker.address().streetAddress()	
              //postcode randomInDetails;
              postcode vars.getObject(&quot;postCodeObj&quot;).generate()
            }
            numPreviousConvictions 3
            prosecutorCosts &quot;20.99&quot;
          }
          individual {
            languageRequirement &quot;no special language needs&quot;
            specificRequirements &quot;no special needs&quot;
            nameDetails {
              title vars.getObject(&quot;randomTitleObj&quot;).generate()
              forename faker.name().firstName()
              surname faker.name().lastName()
            }
            contactDetails {
              primaryEmail faker.name().firstName()+ &quot;@xyz.com&quot;
              secondaryEmail faker.name().lastName()+ &quot;@xyz.com&quot;
            }
            nationality &quot;GBR&quot;
            additionalNationality &quot;POL&quot;
            dateOfBirth dateOfBirthValue
            gender vars.getObject(&quot;genderObj&quot;).generate()
            occupation &quot;TA&quot;
            occupationCode 666
            ethnicity ethnicityValue
            driverNumber  &quot;KER&quot; + faker.number().numberBetween(10000000,99999999).toString() + &quot;SE9RM&quot;
            nationalInsuranceNumber &quot;SN&quot; + faker.number().numberBetween(100000,999999).toString()  + &quot;C&quot;
          } 
          offences([{
              offenceDetails {
                cjsOffenceCode &quot;FB89501&quot; //vars.getObject(&quot;randomOffenceCodeObj&quot;).generate()
                offenceSequenceNo 1
                offenceCommittedDate offenceDates.first()
                offenceCommittedEndDate offenceDates.last()
                offenceDateCode 4
                offenceLocation &quot;Croydon&quot;
                offenceWording &quot;Test Prosecution charge wording&quot;
                offenceWordingWelsh &quot;Test Prosecution charge wording in Welsh&quot;
                prosecutorCompensation faker.number().numberBetween(30,100).toString() + &quot;.&quot; + faker.number().numberBetween(10,99).toString()
                backDuty &quot;+&quot; + faker.number().numberBetween(100,400).toString() + &quot;.&quot; + faker.number().numberBetween(10,99).toString()
                backDutyDateFrom backDutyDates.first()
                backDutyDateTo backDutyDates.last()
                vehicleMake vars.getObject(&quot;randomVehicleObj&quot;).generate()
                vehicleRegistrationMark vars.getObject(&quot;vehicleNumberObj&quot;).generate()
              }
              arrestDate vars.getObject(&quot;dateBuilderObj&quot;).offenceArrestDate()
              chargeDate vars.getObject(&quot;dateBuilderObj&quot;).offenceArrestDate()
              statementOfFacts &quot;1Test Prosecution statements of facts&quot;
              statementOfFactsWelsh &quot;1Welsh -Test Prosecution statements of facts&quot;
            }])
        }])
      paymentReference  &quot;Def1&quot;
    })})
}


def jsonString = payloadBuilder.toPrettyString()
log.info(&quot;jsonString&quot; + jsonString);

vars.putObject(&quot;bulkcivilCasesPayload&quot;, jsonString);
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="createTemporaryVariables" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">vars.put(&quot;NEW_URN&quot;, &quot;${__Random(10, 99)}AZ${__Random(1000000, 9999999)}&quot;);

def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
java.util.Random ran = new java.util.Random();
def tempDays  = ran.nextInt(Integer.parseInt(vars.get(&quot;hearingRandomDays&quot;))) + 2;
def hDate = java.time.LocalDateTime.now().plusDays(tempDays).format(DATETIME_FORMAT);

def weekDate = java.time.LocalDate.parse(hDate);

if(weekDate.getDayOfWeek() == java.time.DayOfWeek.SATURDAY)  {
            weekDate = weekDate.plusDays(2);  }
 else if(weekDate.getDayOfWeek() == java.time.DayOfWeek.SUNDAY) {
 	 	 weekDate = weekDate.plusDays(1);  }

def hearingDate = weekDate.format(DATETIME_FORMAT);
log.info(&quot;hearing_date &quot; +  hearingDate ) ;
vars.put(&quot;HEARING_DATE&quot;, hearingDate); 


vars.put(&quot;DOB1&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);
String timeMillis = Long.toString(System.currentTimeMillis());
vars.put(&quot;REQUEST_ID&quot;, timeMillis + &quot;${__Random(10, 99)}&quot;);

def faker = new com.github.javafaker.Faker();
vars.put(&quot;defendantFirstName&quot;, faker.name().firstName());
vars.put(&quot;defendantLastName&quot;, faker.name().lastName());
vars.put(&quot;streetAddress&quot;, faker.address().streetAddress());

def allOffencesCodes = props.get(&quot;ALL_OFFENCE_CODES&quot;);
random_num = ran.nextInt(allOffencesCodes.size())
def randomOffenceDetails = allOffencesCodes.get(random_num).split(&quot;,&quot;);
vars.put(&quot;offenceCode&quot; , randomOffenceDetails.first());
vars.put(&quot;offenceDescription&quot;, randomOffenceDetails.last()); 

def randomDay  = ${__Random(1,99,)}; 
def offenceStartDate = weekDate.minusYears(2).minusDays(randomDay);
def offenceArrestDate = offenceStartDate.plusMonths(1);

vars.put(&quot;offenceStartDate&quot;, offenceStartDate.format(DATETIME_FORMAT));
vars.put(&quot;offenceArrestDate&quot;, offenceArrestDate.format(DATETIME_FORMAT));

log.info(&quot;REQUEST_ID:&quot; + vars.get(&quot;REQUEST_ID&quot;));
log.info(&quot;destinationID:&quot; + vars.get(&quot;destinationID&quot;));

log.info(&quot;NEW_URN:&quot; + vars.get(&quot;NEW_URN&quot;));
log.info(&quot;originatingOrganisation:&quot; + vars.get(&quot;originatingOrganisation&quot;));
log.info(&quot;courtHearingLocation:&quot; + vars.get(&quot;courtHearingLocation&quot;));
log.info(&quot;HEARING_DATE:&quot; + vars.get(&quot;HEARING_DATE&quot;));
log.info(&quot;prosecutorReference:&quot; + vars.get(&quot;prosecutorReference&quot;));
log.info(&quot;defendantFirstName:&quot; + vars.get(&quot;defendantFirstName&quot;));
log.info(&quot;defendantLastName:&quot; + vars.get(&quot;defendantLastName&quot;));
log.info(&quot;DOB:&quot; + vars.get(&quot;DOB1&quot;));
log.info(&quot;streetAddress:&quot; + vars.get(&quot;streetAddress&quot;));
log.info(&quot;offenceCode:&quot; + vars.get(&quot;offenceCode&quot;));
log.info(&quot;offenceDescription:&quot; + vars.get(&quot;offenceDescription&quot;));
log.info(&quot;offenceStartDate:&quot; + vars.get(&quot;offenceStartDate&quot;));
log.info(&quot;offenceStartDate:&quot; + vars.get(&quot;offenceStartDate&quot;));
log.info(&quot;offenceArrestDate:&quot; + vars.get(&quot;offenceArrestDate&quot;));





</stringProp>
        </JSR223Sampler>

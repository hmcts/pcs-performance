                        <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                        <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                          <collectionProp name="Arguments.arguments">
                            <elementProp name="" elementType="HTTPArgument">
                              <boolProp name="HTTPArgument.always_encode">false</boolProp>
                              <stringProp name="Argument.value">{&quot;pleas&quot;:[{&quot;defendantId&quot;:&quot;${defendantId}&quot;,&quot;offenceId&quot;:&quot;${currentOffenceId}&quot;,&quot;prosecutionCaseId&quot;:&quot;${CASE_ID}&quot;,&quot;allocationDecision&quot;:{&quot;offenceId&quot;:&quot;${currentOffenceId}&quot;,&quot;originatingHearingId&quot;:&quot;${HEARING_ID}&quot;,&quot;motReasonCode&quot;:&quot;01&quot;,&quot;motReasonDescription&quot;:&quot;motReasonDescriptionTest&quot;,&quot;motReasonId&quot;:&quot;${MOT_REASON_ID}&quot;,&quot;allocationDecisionDate&quot;:&quot;${HEARING_DATE}&quot;,&quot;sequenceNumber&quot;:90},&quot;plea&quot;:{&quot;offenceId&quot;:&quot;${currentOffenceId}&quot;,&quot;originatingHearingId&quot;:&quot;${HEARING_ID}&quot;,&quot;pleaDate&quot;:&quot;${HEARING_DATE}&quot;,&quot;pleaValue&quot;:&quot;GUILTY&quot;}}]}</stringProp>
                              <stringProp name="Argument.metadata">=</stringProp>
                            </elementProp>
                          </collectionProp>
                        </elementProp>
                        <stringProp name="HTTPSampler.domain"></stringProp>
                        <stringProp name="HTTPSampler.port"></stringProp>

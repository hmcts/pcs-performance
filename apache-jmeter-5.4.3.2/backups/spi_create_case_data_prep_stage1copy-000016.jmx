                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script"> if (vars.get(&quot;HEARING_ID&quot;) == &quot;NOT_FOUND&quot;) {
   log.info(&quot;Cases without Hearing  &quot; + &quot;${NEW_URN} was checked against date ${HEARING_DATE} in court ${COURT_CENTRE} in courtroom ${courtRoomId}&quot; );
 }

</stringProp>

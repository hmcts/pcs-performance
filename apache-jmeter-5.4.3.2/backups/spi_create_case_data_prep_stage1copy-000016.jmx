          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="readIdpcMetaData" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import org.apache.jmeter.services.FileServer

def inputPath = FileServer.getFileServer().getBaseDir() + &quot;/shared/data/fileUploads/pdfless100KB.txt&quot;
def jsonString = new File(inputPath).text
vars.put(&quot;IDPC_DATA&quot;, jsonString);
log.info(&quot;the inputPath is &quot; +  inputPath);</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="printCaseInfo" enabled="true">
          <stringProp name="BeanShellSampler.query">
String caseDetails = vars.get(&quot;NEW_URN&quot;) + &quot;,&quot; +  &quot;1D-1O&quot; + &quot;,&quot; + vars.get(&quot;firstname&quot;) +  &quot;,&quot; + vars.get(&quot;lastname&quot;) + &quot;,&quot; + vars.get(&quot;DOB&quot;) ;
log.info(&quot;defence case details &quot; + caseDetails);
 vars.put(&quot;INPUT_DATA&quot;,caseDetails)
  




</stringProp>
          <stringProp name="BeanShellSampler.filename"></stringProp>
          <stringProp name="BeanShellSampler.parameters"></stringProp>
          <boolProp name="BeanShellSampler.resetInterpreter">false</boolProp>
        </BeanShellSampler>

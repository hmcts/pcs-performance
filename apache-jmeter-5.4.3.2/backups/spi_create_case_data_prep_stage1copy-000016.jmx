        for(id in ids){
            newChildUUID = UUID.randomUUID().toString()
            tempText = tempText.replace(id,newChildUUID)
            tempMap.put(id,newChildUUID)
        }       
        rel = new JsonSlurper().parseText(tempText).relations
        for(r in rel){
            val = r.resultLineId
            tempMap=[&quot;resultLineId&quot;:r.resultLineId,&quot;childResultLineIds&quot;:r.childResultLineIds]
            resLines = new JsonSlurper().parseText(tempText).resultLines
            for(resLine in resLines){
                resLineVal = resLine.getValue()
                if(resLineVal.resultLineId.equalsIgnoreCase(val)){
                    tempMap.put(&quot;valid&quot;,resLineVal.valid)
                    tempMap.put(&quot;defendantId&quot;,defendantId)
                    tempMap.put(&quot;offenceId&quot;,offenceId)
                    tempMap.put(&quot;originalText&quot;,resLineVal.originalText)
                    tempMap.put(&quot;caseId&quot;,resLineVal.caseId)
                }
            }

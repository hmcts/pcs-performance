	SampleResult.setResponseMessage(&quot;ManageHearingAndShareResults: No Hearing ID was found&quot;);
 
//set Response Data
	SampleResult.setResponseData(&quot;ManageHearingAndShareResults: No Hearing ID was found&quot; , &quot;UTF-8&quot;); //+ vars.get(&quot;NEW_URN&quot;)

//set Response Data
	SampleResult.setResponseCode(&quot;418&quot;);

//set Failure
	SampleResult.setSuccessful(false);

</stringProp>

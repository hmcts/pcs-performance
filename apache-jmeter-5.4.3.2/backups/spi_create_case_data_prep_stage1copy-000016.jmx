                      <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract hearing Id from public event  " enabled="true">
                        <stringProp name="JSONPostProcessor.referenceNames">hearingIdFromSaveDraftResult</stringProp>
                        <stringProp name="JSONPostProcessor.jsonPathExprs">$.events[?(@._metadata.correlation.client==&apos;${cppClientCorrelationIdForSaveDraftResult}&apos; &amp;&amp; @._metadata.name==&apos;public.hearing.draft-result-saved&apos;)]._metadata.stream.id</stringProp>
                        <stringProp name="JSONPostProcessor.match_numbers">0</stringProp>
                        <stringProp name="JSONPostProcessor.defaultValues">NO_HEARING_STATUS</stringProp>

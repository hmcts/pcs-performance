                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="reconstructAmendSaveResultsPayload" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.*
import org.apache.jmeter.services.FileServer

def shareResultsPayload = vars.getObject(&quot;sharedResultPayload&quot;);
def parsed = new JsonSlurper().parseText(shareResultsPayload)
def finalResultLines = [];

//def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
def weekDate = java.time.LocalDate.parse(vars.get(&quot;HEARING_DATE&quot;));
def fixedDate = weekDate.plusDays(10).toString();
vars.put(&quot;fixedDate&quot;, fixedDate);


log.info(&quot;fixedDate &quot; + vars.get(&quot;fixedDate&quot;));
log.info(&quot;newFixedDate:&quot; + vars.get(&quot;newFixedDate&quot;));
log.info(&quot;resultCode: &quot; + vars.get(&quot;resultCode&quot;));

if (vars.get(&quot;resultCode&quot;).equals(&apos;A&apos;)) {
    resultLines = parsed.resultLines
    for (resultLine in resultLines) {
//        log.info(&quot;result lines &quot; + resultLine.shortCode);
        if (resultLine.shortCode.equals(&quot;nhccs&quot;)) {
            def todayAmendmentDate = java.time.ZonedDateTime.now().
                    format(java.time.format.DateTimeFormatter.ISO_INSTANT).toString();

            def amendmentReason = [&quot;amendmentReasonId&quot;:&quot;a02018a1-915c-3343-95ad-abc5f99b339a&quot;,
                                   &quot;amendmentReason&quot;:&quot;Error or Omission in result announced in court (Amendment under the Slip rule)&quot;,
                                   &quot;amendmentDate&quot;: todayAmendmentDate]
            resultLine = resultLine + amendmentReason
            for( prompts in resultLine.prompts ) {
                if(prompts.label.equals(&quot;Fixed Date&quot;)) {
                    prompts.value = vars.get(&quot;newFixedDate&quot;);
                }
            }
        }
        finalResultLines.add(resultLine)
    }
}
parsed.resultLines = finalResultLines;
newJsonOut = JsonOutput.prettyPrint(JsonOutput.toJson(parsed))
//log.info(&quot;newJsonOut &quot; + newJsonOut);
vars.putObject(&quot;amendedShareResultsPayload&quot;, newJsonOut);
 


                             </stringProp>
                  </JSR223Sampler>

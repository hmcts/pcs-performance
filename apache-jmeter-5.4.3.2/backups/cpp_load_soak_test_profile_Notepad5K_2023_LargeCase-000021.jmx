          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Pacing Controller_${SCENARIO_NAME}" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.util.concurrent.ThreadLocalRandom;

vars.put(&quot;iterationCount&quot;, vars.getIteration().toString());
log.info(&quot;iteration: &quot; + vars.get(&quot;iterationCount&quot;));

//To give ${pacingIntervalTime} some element of randomisation
int minRand = Integer.parseInt(vars.get(&quot;pacingIntervalTimeCPS&quot;))-12000;
int maxRand = Integer.parseInt(vars.get(&quot;pacingIntervalTimeCPS&quot;))+12001;
def randomNum  = ThreadLocalRandom.current().nextInt(minRand,maxRand);
vars.put(&quot;pacingIntervalTimeCPSTemp&quot;, String.valueOf(randomNum));
//log.info(&quot;randomNum: &quot; + randomNum);</stringProp>
          </JSR223Sampler>

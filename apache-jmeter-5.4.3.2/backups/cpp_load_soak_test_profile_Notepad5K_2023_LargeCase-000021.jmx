          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Pacing Controller_${SCENARIO_NAME}" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.util.concurrent.ThreadLocalRandom;

vars.put(&quot;iterationCount&quot;, vars.getIteration().toString());
log.info(&quot;iteration: &quot; + vars.get(&quot;iterationCount&quot;));

//To give ${pacingIntervalTime} some element of randomisation
int minRand = Integer.parseInt(vars.get(&quot;pacingIntervalTimeLAA&quot;))-12000;
int maxRand = Integer.parseInt(vars.get(&quot;pacingIntervalTimeLAA&quot;))+12001;
def randomNum  = ThreadLocalRandom.current().nextInt(minRand,maxRand);
vars.put(&quot;pacingIntervalTimeLAATemp&quot;, String.valueOf(randomNum));
//log.info(&quot;randomNum: &quot; + randomNum);</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Controller" enabled="true">
            <stringProp name="IfController.condition">${__jexl3(&quot;${iterationCount}&quot;!=&quot;1&quot;)}</stringProp>
            <boolProp name="IfController.evaluateAll">false</boolProp>
            <boolProp name="IfController.useExpression">true</boolProp>
          </IfController>
          <hashTree>
            <TestAction guiclass="TestActionGui" testclass="TestAction" testname="WaitForLAAActivityToComplete" enabled="true">
              <intProp name="ActionProcessor.action">1</intProp>
              <intProp name="ActionProcessor.target">0</intProp>
              <stringProp name="ActionProcessor.duration">${pacingIntervalTimeLAATemp}</stringProp>
            </TestAction>
            <hashTree/>
          </hashTree>
        </hashTree>

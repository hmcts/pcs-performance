          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.commons.io.FileUtils;   
import org.apache.jmeter.services.FileServer

def getRandomRowFromCsv(inputPath) {
	//def inputPath = FileServer.getFileServer().getBaseDir() + &quot;/spi/data/offenceCodes.csv&quot;;
	//def administratorCsvDatapath = basePath + &quot;/unprocessedUnallocatedCaseURNsForAdminstrators.csv&quot;;
     List csvData = FileUtils.readLines(new File(inputPath));
     return csvData
}

//def incodePath = &quot;FileServer.getFileServer().getBaseDir() + &quot;/shared/data/incodes.csv&quot;;
//def outcodePath = &quot;FileServer.getFileServer().getBaseDir() + &quot;/shared/data/outcodes.csv&quot;;

def incodePath = FileServer.getFileServer().getBaseDir() + &quot;/shared/data/incodes.csv&quot;;
def outcodePath = FileServer.getFileServer().getBaseDir() + &quot;/shared/data/outcodes.csv&quot;;

props.put(&quot;ALL_IN_CODES&quot;, getRandomRowFromCsv(incodePath));
props.put(&quot;ALL_OUT_CODES&quot;, getRandomRowFromCsv(outcodePath));

vars.put(&quot;SCENARIO_NAME&quot;,ctx.getThreadGroup().getName().toString())

</stringProp>

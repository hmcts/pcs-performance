          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">props.put(&quot;TARGET_NFT01&quot;,&quot;false&quot;);
props.put(&quot;TARGET_NFT02&quot;,&quot;false&quot;);

if (String.valueOf(vars.get(&quot;slaveSuffix&quot;)) == &apos;&quot;a&quot;&apos;||String.valueOf(vars.get(&quot;slaveSuffix&quot;)) == &quot;a&quot;)
{
	vars.put(&quot;slaveSuffix&quot;, &quot;a&quot;);
	log.info(&quot;slaveSuffix: &quot; + vars.get(&quot;slaveSuffix&quot;));
}

if (vars.get(&quot;envType&quot;) == &quot;nftccm01&quot;)
{
	props.put(&quot;TARGET_NFT01&quot;,&quot;true&quot;);
}

if (vars.get(&quot;envType&quot;) ==&quot;nftccm02&quot;)
{
	props.put(&quot;TARGET_NFT02&quot;,&quot;true&quot;);
}


	def path  = vars.get(&quot;expDir&quot;) + &apos;setJDBCVars.log&apos;;

	FileWriter fWriter = new FileWriter(path, true);
	BufferedWriter buff = new BufferedWriter(fWriter);
	String todaysDate = &quot;${__time(yyyy-MM-dd HH:mm:ss)}&quot;;

	buff.write(&quot;slaveSuffix: &quot; + vars.get(&quot;slaveSuffix&quot;) + &quot;\r\n&quot;);
	buff.write(&quot;TARGET_NFT01: &quot; + props.get(&quot;TARGET_NFT01&quot;) + &quot;\r\n&quot;);
	buff.write(&quot;TARGET_NFT02: &quot; + props.get(&quot;TARGET_NFT02&quot;) + &quot;\r\n&quot;);

	buff.close();
	fWriter.close();

</stringProp>

            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import  org.apache.commons.lang3.*;

class UrnGenerator {

    def randomNumber(lowerLimit, upperLimit) {
        Math.abs(new Random().nextInt() % ([upperLimit] - [lowerLimit])) + [lowerLimit]
    }

    def randomNumbering(int number) {
    	org.apache.commons.lang3.RandomStringUtils.randomNumeric(number);
    }

    def newUrn() {
    	//+ randomNumber(10, 99) + &quot;XD&quot;
        &quot;CVILNFT2604&quot;  + randomNumber(1000000, 9999999)
    }

  //org.apache.commons.lang3.RandomStringUtils.random(1, 1, 9, false, true)
    def pncIdentifier() {
    randomNumber(1, 9) + this.randomNumbering(3) + &quot;/&quot; + this.randomNumbering(7) + org.apache.commons.lang3.RandomStringUtils.randomAlphabetic(1);
	}

	def croNumber() {
     this.randomNumbering(6) + &quot;/&quot; + this.randomNumbering(2) + this.randomNumbering(1);
	}

//    def pncIdentifier() {
//        randomNumber(0000, 3333) + &quot;/&quot; + randomNumber(100000, 999999) + &quot;L&quot;
//    }
//
//    def croNumber() {
//        randomNumber(000000, 333333) + &quot;/&quot; + randomNumber(10, 99) + &quot;L&quot;
//
//    }
}


class ListRandomizer {
	def static get(ArrayList list) {
	   def ran = new Random();     
        def randomNumber = ran.nextInt(list.size());
        list[randomNumber];
}

}

class RandomPostCode {
//DEPRECATED

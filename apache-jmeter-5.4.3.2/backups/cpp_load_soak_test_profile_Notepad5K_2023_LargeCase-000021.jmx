        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="setLocalVariables" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">def path  = vars.get(&quot;baseDir&quot;) + &apos;/spi/data/courtsNFTrefdata.csv&apos;;

def csvfile = new File(path);
def lines = csvfile.readLines()
lines.each {line -&gt;
    def courtLines = line.split(&quot;,&quot;);
    if (courtLines[0] == vars.get(&quot;COURT_CENTRE&quot;)) {
    	vars.put(&quot;COURT_ROOM&quot;, courtLines[1]);
    	vars.put(&quot;OUCODE&quot;,courtLines[2]);
    	return;
}
}
</stringProp>
        </JSR223Sampler>

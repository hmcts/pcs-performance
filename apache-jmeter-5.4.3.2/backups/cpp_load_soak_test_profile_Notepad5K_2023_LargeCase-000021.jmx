class DateBuilder {
    def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
    def randomDay = new UrnGenerator().randomNumber(20, 200);
        
    def hearingDate() {
        java.util.Random ran = new java.util.Random();
        def tempDays = ran.nextInt(20 + 2);
        def hDate = java.time.LocalDateTime.now().plusDays(tempDays).format(DATETIME_FORMAT);
        def weekDate = java.time.LocalDate.parse(hDate);
        if (weekDate.getDayOfWeek() == java.time.DayOfWeek.SATURDAY) {
            weekDate = weekDate.plusDays(2);
        } else if (weekDate.getDayOfWeek() == java.time.DayOfWeek.SUNDAY) {
            weekDate = weekDate.plusDays(1);
        }
        weekDate.format(DATETIME_FORMAT);
    }

    def dateOfBirth() {
        def randomAgeNo = new UrnGenerator().randomNumber(20, 80);
        java.time.LocalDateTime.now().minusYears(randomAgeNo).format(DATETIME_FORMAT);
    }

    def List offenceDate() {

        def offenceStartDate = java.time.LocalDateTime.now().minusDays(randomDay).format(DATETIME_FORMAT).toString();
        def offenceEndDate = java.time.LocalDateTime.now().minusDays(randomDay + 1).format(DATETIME_FORMAT).toString();
        [offenceStartDate, offenceEndDate]
    }

	def offenceArrestDate() {
		java.time.LocalDateTime.now().minusDays(randomDay - 21).format(DATETIME_FORMAT).toString();
	}
	

    def List backDutyDate() {
        def randomDay = new UrnGenerator().randomNumber(100, 300);
        def backDutyStartDate = java.time.LocalDateTime.now().minusDays(randomDay).format(DATETIME_FORMAT).toString();
        def backDutyEndDate = java.time.LocalDateTime.now().minusDays(randomDay + 1).format(DATETIME_FORMAT).toString();
        [backDutyStartDate, backDutyEndDate]
    }


}


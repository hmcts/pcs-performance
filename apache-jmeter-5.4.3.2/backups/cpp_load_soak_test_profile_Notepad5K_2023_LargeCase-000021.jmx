buff.write(&quot;From &quot; + props.get(&quot;legalAdvisorsLargeCaseCsvDatapath&quot;) + &quot;, remove &quot; + vars.get(&quot;NEW_URN&quot;) + &quot;\r\n&quot;);
buff.close();
fWriter.close();


//log.info(&quot;*****&quot; + vars.get(&quot;expDir&quot;) + &quot;\\output\\allocated_hearing_output.csv&quot; + &quot;*****&quot;);

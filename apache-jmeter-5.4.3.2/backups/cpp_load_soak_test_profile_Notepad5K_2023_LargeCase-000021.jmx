              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import java.time.LocalDateTime;
import com.github.javafaker.Faker;
// import net.datafaker.Faker;
java.util.Random ran = new java.util.Random();


def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);

//Hearing Dates
LocalDateTime hearingDate = LocalDateTime.now();
LocalDateTime hearingDate2 = hearingDate.plusDays(1)
String shearingDate = hearingDate.format(DATETIME_FORMAT);
String shearingDate2 = hearingDate2.format(DATETIME_FORMAT);
vars.put(&quot;hearingDate&quot;, shearingDate);
vars.put(&quot;hearingDate2&quot;, shearingDate2);

//URN
vars.put(&quot;NEW_URN&quot;, &quot;${__Random(10, 99)}OCT${__Random(1000000, 9999999)}&quot;);
</stringProp>
                <stringProp name="TestPlan.comments">//log.info(&quot;hearingDate: &quot; + hearingDate);
//log.info(&quot;hearingDate2: &quot; + hearingDate2);
//log.info(&quot;shearingDate: &quot; + shearingDate);
//log.info(&quot;shearingDate2: &quot; + shearingDate2);
</stringProp>
              </JSR223PreProcessor>

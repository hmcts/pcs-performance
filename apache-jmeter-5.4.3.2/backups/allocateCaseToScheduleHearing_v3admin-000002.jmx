            <stringProp name="script">
def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
def hearingdate = java.time.LocalDate.parse(vars.get(&quot;HEARING_DATE&quot;));
def hearingEndDate =  hearingdate.plusDays(10);  
vars.put(&quot;HEARING_END_DATE&quot;, hearingEndDate.format(DATETIME_FORMAT));
def fromdate = java.time.LocalDateTime.now().format(DATETIME_FORMAT).toString();
vars.put(&quot;FromDate&quot;,fromdate); </stringProp>

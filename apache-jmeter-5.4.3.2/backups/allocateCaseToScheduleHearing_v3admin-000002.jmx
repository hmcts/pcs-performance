          <hashTree>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="computePayloadForListingAllocateAllDefendantsAndOffences" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="script">import groovy.json.JsonBuilder;
import groovy.json.JsonSlurper;
import groovy.json.JsonOutput;

def jsonSlurper = new JsonSlurper();
def payloadBuilder = new JsonBuilder()
def orderedDate = new Date().format(&apos;yyyy-MM-dd&apos;).toString();
def nextHearingDate = vars.get(&quot;HEARING_DATE&quot;);
def allDefendants = vars.getObject(&quot;DEFENDANTID_ALL&quot;).split(&apos;,&apos;);
def defendantsSize  = allDefendants.size();
def defendantPayload = [];  
                
def prosecutionCaseDetails = jsonSlurper.parseText(vars.getObject(&quot;prosecutionCase&quot;));
allDefendants.eachWithIndex { id, dIndex -&gt;
    def builder = new groovy.json.JsonBuilder()		
    def matchedDefendant = prosecutionCaseDetails.defendants.findAll { it.id == id };
    def allOffences = matchedDefendant[0].caagDefendantOffences.collect { it.id } 



   builder {
    defendantId id
    offences allOffences.collect {[offenceId: it]}    
   }
   defendantPayload.add(builder);
}  


payloadBuilder {
   courtCentreId vars.get(&quot;COURT_CENTRE&quot;)
   courtRoomId vars.get(&quot;COURT_ROOM&quot;)
   endDate vars.get(&quot;HEARING_DATE&quot;)
   jurisdictionType &apos;MAGISTRATES&apos;
   hearingLanguage &apos;ENGLISH&apos;
   nonDefaultDays ( [ {
    startTime vars.get(&quot;HEARING_DATE&quot;)+&quot;T10:00:00.000Z&quot;
    duration 1
    courtScheduleId &apos;${courtScheduleId}&apos;
    courtCentreId vars.get(&quot;COURT_CENTRE&quot;)
    session &apos;AD&apos;
    oucode vars.get(&quot;OUCODE&quot;)
    courtRoomId 2331
    roomId vars.get(&quot;COURT_ROOM&quot;)
   }])
   nonSittingDays([])
   prosecutionCases([{
      caseId vars.get(&quot;CASE_ID&quot;)
      defendants defendantPayload.content.collect { it }
   }])
  startDate vars.get(&quot;HEARING_DATE&quot;)
  publicListNote &apos;&apos;
  hasVideoLink false
  type {
    id &apos;${firsthearingId}&apos;
    description &apos;First hearing&apos;
  }
  judiciary([])
  }


vars.put(&quot;listingAllocatePayload&quot;, payloadBuilder.toPrettyString());


//log.info(&quot;printing payload***********\r\n&quot; + payloadBuilder.toPrettyString());
</stringProp>
            </JSR223Sampler>

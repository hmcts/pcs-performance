{
	vars.put(&quot;CaseAllocationNotificationPollingEnded&quot;, &quot;true&quot;);
     prev.setSuccessful(true);
}
else
{
	new_iteration_value = Integer.parseInt(vars.get(&quot;pollingIterationCounter&quot;)) + 1 ;
	vars.put(&quot;pollingIterationCounter&quot;, String.valueOf(new_iteration_value));

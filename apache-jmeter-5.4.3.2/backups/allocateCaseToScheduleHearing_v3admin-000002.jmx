	log.error(&quot;COURT_ROOM:&quot; + vars.get(&quot;COURT_ROOM&quot;));
	log.error(&quot;OUCODE:&quot; + vars.get(&quot;OUCODE&quot;));
	log.error(&quot;listingAllocatePayload: &quot; + vars.get(&quot;listingAllocatePayload&quot;));
	log.error(&quot;*************** END ***********************&quot;);

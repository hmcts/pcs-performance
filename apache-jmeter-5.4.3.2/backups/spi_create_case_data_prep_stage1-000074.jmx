          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="computeDate" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
            <stringProp name="script">def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);

def fromdate = java.time.LocalDateTime.now().plusDays(4).format(DATETIME_FORMAT).toString();
vars.put(&quot;FromDate&quot;,fromdate);

def todate = java.time.LocalDateTime.now().plusDays(10).format(DATETIME_FORMAT).toString();
vars.put(&quot;ToDate&quot;,todate);</stringProp>
          </JSR223Sampler>

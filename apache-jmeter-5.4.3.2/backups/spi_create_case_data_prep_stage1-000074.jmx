              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="script">def faker = new com.github.javafaker.Faker();

vars.put(&quot;firstName&quot;,faker.name().firstName());
vars.put(&quot;lastName&quot;,faker.name().lastName());
vars.put(&quot;address1&quot;,faker.address().streetName());
vars.put(&quot;address2&quot;,faker.address().state());
vars.put(&quot;address3&quot;,faker.address().cityName());
vars.put(&quot;address4&quot;,faker.address().state());

</stringProp>

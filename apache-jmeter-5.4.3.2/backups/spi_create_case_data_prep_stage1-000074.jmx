          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="createcourtsession" enabled="true">
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{&#xd;
    &quot;sessions&quot;: [&#xd;
        {&#xd;
            &quot;courtCentreId&quot;: &quot;${COURTCENTRE_ID}&quot;,&#xd;
            &quot;courtRoomId&quot;: &quot;${COURTROOM_ID}&quot;,&#xd;
            &quot;sessionType&quot;: &quot;AM&quot;,&#xd;
            &quot;businessType&quot;: &quot;REM&quot;,&#xd;
            &quot;duration&quot;: 10,&#xd;
            &quot;allDaySplit&quot;: false,&#xd;
            &quot;sessionStartTime&quot;: &quot;08:00&quot;,&#xd;
            &quot;sessionEndTime&quot;: &quot;13:00&quot;,&#xd;
            &quot;isOverbookingAllowed&quot;: true,&#xd;
            &quot;panel&quot;: &quot;ADULT&quot;,&#xd;
            &quot;repeatDays&quot;: [&#xd;
                &quot;Monday&quot;,&#xd;
                &quot;Tuesday&quot;,&#xd;
                &quot;Wednesday&quot;,&#xd;
                &quot;Thursday&quot;,&#xd;
                &quot;Friday&quot;,&#xd;
                &quot;Saturday&quot;,&#xd;
                &quot;Sunday&quot;&#xd;
            ]&#xd;
        },&#xd;
        {&#xd;
            &quot;courtCentreId&quot;: &quot;${COURTCENTRE_ID}&quot;,&#xd;
            &quot;courtRoomId&quot;: &quot;${COURTROOM_ID}&quot;,&#xd;
            &quot;sessionType&quot;: &quot;PM&quot;,&#xd;
            &quot;businessType&quot;: &quot;REM&quot;,&#xd;
            &quot;duration&quot;: 10,&#xd;
            &quot;allDaySplit&quot;: false,&#xd;
            &quot;sessionStartTime&quot;: &quot;14:00&quot;,&#xd;
            &quot;sessionEndTime&quot;: &quot;18:00&quot;,&#xd;
            &quot;isOverbookingAllowed&quot;: true,&#xd;
            &quot;panel&quot;: &quot;ADULT&quot;,&#xd;
            &quot;repeatDays&quot;: [&#xd;
                &quot;Monday&quot;,&#xd;
                &quot;Tuesday&quot;,&#xd;
                &quot;Wednesday&quot;,&#xd;
                &quot;Thursday&quot;,&#xd;
                &quot;Friday&quot;,&#xd;
                &quot;Saturday&quot;,&#xd;
                &quot;Sunday&quot;&#xd;
            ]&#xd;
        }&#xd;
    ],&#xd;

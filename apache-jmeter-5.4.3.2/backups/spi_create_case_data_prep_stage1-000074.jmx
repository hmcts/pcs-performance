          <stringProp name="BeanShellSampler.query">String caseUrn = vars.get(&quot;NEW_URN&quot;);
String caseDetails = caseUrn + &quot;,&quot; +  &quot;1D-1O&quot; + &quot;,&quot; + vars.get(&quot;COURT_CENTRE&quot;) + &quot;,&quot; + vars.get(&quot;COURT_ROOM&quot;) + &quot;,&quot; + vars.get(&quot;courtHearingLocation&quot;) +  &quot;\n&quot;;
log.info(&quot;SPI error cases &quot; + caseDetails);

  




</stringProp>

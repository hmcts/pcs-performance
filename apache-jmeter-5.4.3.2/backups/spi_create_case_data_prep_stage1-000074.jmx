        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="setSPiCaseDetails" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.commons.io.FileUtils;   

import org.apache.jmeter.services.FileServer

def getRandomRowFromCsv() {
	def inputPath = FileServer.getFileServer().getBaseDir() + &quot;/spi/data/offenceCodes.csv&quot;;
     List csvData = FileUtils.readLines(new File(inputPath));
     return csvData
}
props.put(&quot;ALL_OFFENCE_CODES&quot;, getRandomRowFromCsv());

def location = vars.get(&quot;courtHearingUnallocatedLocation&quot;);
def roomCode =  vars.get(&quot;courtroomCode&quot;);
def courtLocation = location.substring(0,5) + roomCode;
vars.put(&quot;courtHearingLocation&quot;, courtLocation);
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <ThroughputController guiclass="ThroughputControllerGui" testclass="ThroughputController" testname="Case with 1D and 1O" enabled="true">
          <intProp name="ThroughputController.style">0</intProp>
          <boolProp name="ThroughputController.perThread">false</boolProp>
          <stringProp name="ThroughputController.maxThroughput"></stringProp>
          <FloatProperty>
            <name>ThroughputController.percentThroughput</name>
            <value>15.0</value>
            <savedValue>0.0</savedValue>
          </FloatProperty>
          <stringProp name="TestPlan.comments">15.0</stringProp>
        </ThroughputController>
        <hashTree>
          <IncludeController guiclass="IncludeControllerGui" testclass="IncludeController" testname="CreateSPICaseMinimalFields" enabled="true">
            <stringProp name="IncludeController.includepath">./spi/components/CreateSPICaseMinimalFieldsWith1DefendantAnd1Offence.jmx</stringProp>
          </IncludeController>
          <hashTree/>
          <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="printCaseInfo" enabled="true">
            <stringProp name="BeanShellSampler.query"> String location = vars.get(&quot;courtHearingUnallocatedLocation&quot;);
 String caseUrn = vars.get(&quot;NEW_URN&quot;);
 String courtCenter = vars.get(&quot;COURT_CENTRE&quot;);
 String courtRoom = vars.get(&quot;COURT_ROOM&quot;);
 String hearingDate = vars.get(&quot;HEARING_DATE&quot;);
 String caseDetails = caseUrn + &quot;,&quot; + hearingDate + &quot;,&quot; + courtCenter + &quot;,&quot; +  courtRoom + &quot;,&quot; +  &quot;1D-1O&quot;;
 log.info(&quot;allocated cases without material &quot; + caseDetails);
 vars.put(&quot;INPUT_DATA&quot;,caseDetails)


</stringProp>
            <stringProp name="BeanShellSampler.filename"></stringProp>
            <stringProp name="BeanShellSampler.parameters"></stringProp>
            <boolProp name="BeanShellSampler.resetInterpreter">false</boolProp>
          </BeanShellSampler>
          <hashTree/>
          <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="delayOf5S" enabled="true">
            <stringProp name="ConstantTimer.delay">7000</stringProp>
          </ConstantTimer>
          <hashTree/>
        </hashTree>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="setSPICaseDetails" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">import org.apache.commons.io.FileUtils;   
import org.apache.jmeter.services.FileServer

vars.put(&quot;NEW_URN&quot;, &quot;${__time(mmss,)}BA${__Random(10000, 99999)}&quot;);
vars.put(&quot;DOB&quot;, &quot;${__Random(1910, 1999)}-${__Random(10, 12)}-${__Random(10, 28)}&quot;);
String timeMillis = Long.toString(System.currentTimeMillis());
vars.put(&quot;REQUEST_ID&quot;, timeMillis + &quot;${__Random(10, 99)}&quot;);

def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
def hDate = java.time.LocalDateTime.now().plusDays(${__Random(2,50,)}).format(DATETIME_FORMAT);
vars.put(&quot;HEARING_DATE&quot;,hDate); 

def faker = new com.github.javafaker.Faker();
vars.put(&quot;firstname&quot;, faker.name().firstName());
vars.put(&quot;lastname&quot;, faker.name().lastName());
vars.put(&quot;streetAddress&quot;, faker.address().streetAddress());


def getRandomRowFromCsv() {
	def inputPath = FileServer.getFileServer().getBaseDir() + &quot;/spi/data/offenceCodes.csv&quot;;
     List csvData = FileUtils.readLines(new File(inputPath));
     return csvData
}
props.put(&quot;ALL_OFFENCE_CODES&quot;, getRandomRowFromCsv());


</stringProp>
        </JSR223Sampler>

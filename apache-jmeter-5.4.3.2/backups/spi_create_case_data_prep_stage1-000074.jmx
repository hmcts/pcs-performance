          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="stagingprosecutorsspi" enabled="true">
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">&lt;NS1:Envelope xmlns:NS1=&quot;http://schemas.xmlsoap.org/soap/envelope/&quot;&gt;&#xd;
    &lt;NS1:Body&gt;&#xd;
        &lt;NS2:SubmitRequestMes xmlns:NS2=&quot;http://schemas.cjse.gov.uk/endpoint/types/&quot;&gt;&#xd;
            &lt;NS2:RequestID&gt;${REQUEST_ID}&lt;/NS2:RequestID&gt;&#xd;
            &lt;NS2:SourceID&gt;Z00CJSE&lt;/NS2:SourceID&gt;&#xd;
            &lt;NS2:DestinationID&gt;B00LIBRA&lt;/NS2:DestinationID&gt;&#xd;
            &lt;NS2:ExecMode&gt;ASYNCH&lt;/NS2:ExecMode&gt;&#xd;
            &lt;NS2:Timestamp&gt;2019-02-06T14:27:48Z&lt;/NS2:Timestamp&gt;&#xd;
            &lt;NS2:Message&gt;&amp;lt;RouteData xmlns=&quot;http://schemas.cjse.gov.uk/common/operations&quot; xmlns:cjseEntity=&quot;http://schemas.cjse.gov.uk/common/businessentities&quot; xmlns:cjseType=&quot;http://schemas.cjse.gov.uk/common/businesstypes&quot; xmlns:xsi=&quot;http://www.w3.org/2001/XMLSchema-instance&quot; VersionNumber=&quot;1.0&quot; RequestResponse=&quot;Request&quot;&amp;gt;&amp;lt;RequestFromSystem VersionNumber=&quot;1.0&quot;&amp;gt;&amp;lt;CorrelationID&amp;gt;${REQUEST_ID}&amp;lt;/CorrelationID&amp;gt;&amp;lt;SystemID literalvalue=&quot;CJSE&quot;&amp;gt;Z00CJASE&amp;lt;/SystemID&amp;gt;&amp;lt;OrganizationalUnitID literalvalue=&quot;CJIT CJSE&quot;&amp;gt;Z000000&amp;lt;/OrganizationalUnitID&amp;gt;&amp;lt;DataController literalvalue=&quot;String&quot;&amp;gt;lee.flaxington&amp;lt;/DataController&amp;gt;&amp;lt;User literalvalue=&quot;String&quot;&amp;gt;lee.flaxington&amp;lt;/User&amp;gt;&amp;lt;SourceID literalvalue=&quot;String&quot;&amp;gt;00101PoliceCaseSystem&amp;lt;/SourceID&amp;gt;&amp;lt;DestinationID literalvalue=&quot;String&quot;&amp;gt;Z00CJSE&amp;lt;/DestinationID&amp;gt;&amp;lt;TestOperation&amp;gt;1&amp;lt;/TestOperation&amp;gt;&amp;lt;/RequestFromSystem&amp;gt;&amp;lt;DataStream VersionNumber=&quot;1.0&quot;&amp;gt;&amp;lt;cjseEntity:System literalvalue=&quot;String&quot;&amp;gt;00101PoliceCaseSystem&amp;lt;/cjseEntity:System&amp;gt;&amp;lt;cjseEntity:DataStreamType literalvalue=&quot;String&quot;&amp;gt;SPINewCase&amp;lt;/cjseEntity:DataStreamType&amp;gt;&amp;lt;cjseEntity:SystemDataStreamID&amp;gt;06_02_2019_142719_000000309381&amp;lt;/cjseEntity:SystemDataStreamID&amp;gt;&amp;lt;cjseEntity:Name&amp;gt;SPI New Case&amp;lt;/cjseEntity:Name&amp;gt;&amp;lt;cjseEntity:Reference&amp;gt;06_02_2019_142719_000000309381&amp;lt;/cjseEntity:Reference&amp;gt;&amp;lt;cjseEntity:ReferenceType&amp;gt;SPINewCase&amp;lt;/cjseEntity:ReferenceType&amp;gt;&amp;lt;cjseEntity:Dated&amp;gt;2013-12-01&amp;lt;/cjseEntity:Dated&amp;gt;&amp;lt;cjseEntity:Timed&amp;gt;14:27:21.657Z&amp;lt;/cjseEntity:Timed&amp;gt;&amp;lt;cjseEntity:ContentType&amp;gt;text/plain&amp;lt;/cjseEntity:ContentType&amp;gt;&amp;lt;cjseEntity:DataStreamContent&amp;gt;&amp;amp;lt;?xml version=&amp;amp;quot;1.0&amp;amp;quot; encoding=&amp;amp;quot;utf-8&amp;amp;quot;?&amp;amp;gt;&#xd;
&#xd;
&#xd;
                &amp;amp;lt;DC:NewCaseMessage xmlns:DC=&quot;http://www.dca.gov.uk/xmlschemas/libra&quot; Flow=&quot;NewCasesFromThePolice&quot; Interface=&quot;LibraStandardProsecutorPolice&quot; SchemaVersion=&quot;0.6g&quot;&amp;amp;gt;&#xd;
                &amp;amp;lt;DC:Case&amp;amp;gt;&#xd;
                &amp;amp;lt;DC:PTIURN&amp;amp;gt;${NEW_URN}&amp;amp;lt;/DC:PTIURN&amp;amp;gt;&#xd;

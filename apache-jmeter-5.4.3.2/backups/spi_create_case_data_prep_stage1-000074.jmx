        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="computePayloadForUpdateHearingDetails" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
            <stringProp name="script">import groovy.json.*
def payloadBuilder = new JsonBuilder();

def counter = 1; 	
def isDeputyValue = true
def isBenchChairmanValue = false
def juidicaryIdValue = vars.get(&quot;JUDICIARY_ID1&quot;);

def DATETIME_FORMAT = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
def hearingDate = java.time.LocalDateTime.now().format(DATETIME_FORMAT);

payloadBuilder{
  selectedCourtCentre {
    id vars.get(&quot;COURT_CENTRE&quot;)
    courtRoomId vars.get(&quot;COURT_ROOM&quot;)
    courtCentreName vars.get(&quot;COURT_CENTRE_NAME&quot;)
    ouCode vars.get(&quot;ouCode&quot;)
 //   ouCode &quot;B47GL00&quot;
  } 
   courtCentreId vars.get(&quot;COURT_CENTRE&quot;)
   courtRoomId vars.get(&quot;COURT_ROOM&quot;)
   type{
     id vars.get(&quot;hearingTypeId&quot;)
     description &quot;First hearing&quot;
  } 
   startDate hearingDate
   endDate hearingDate
   nonSittingDays([])
   nonDefaultDays([
     {
       courtCentreId vars.get(&quot;COURT_CENTRE&quot;)
       roomId vars.get(&quot;COURT_ROOM&quot;)
       startTime hearingDate+&quot;T10:00:00.000Z&quot;
       duration 20 }
       ])
    judiciary((1..2).collect {
   	({{
   	 if (counter == 2 ) {
   	 	isDeputyValue = false
          isBenchChairmanValue = true
          juidicaryIdValue = vars.get(&quot;JUDICIARY_ID2&quot;);
   	 }
       judicialId juidicaryIdValue
       judicialRoleType {
         judiciaryType &quot;MAGISTRATE&quot;
      } 
       isDeputy isDeputyValue 
       isBenchChairman isBenchChairmanValue
       counter = counter + 1 
     }})
 })
   jurisdictionType &quot;MAGISTRATES&quot;
   hearingLanguage &quot;ENGLISH&quot;
   publicListNote &quot;&quot;  
   hasVideoLink  false
}

def updateHearingPayload = payloadBuilder.toPrettyString();
vars.put(&quot;updateHearingPayload&quot;,updateHearingPayload);</stringProp>
          </JSR223Sampler>
